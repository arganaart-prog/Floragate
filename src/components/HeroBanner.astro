---
import { WHATSAPP_NUMBER } from '../data/constants';

const panoramaImage = '/images/banner/Panorama.png';
const mobileHeroImage = '/images/produk/wedding-sweet.webp';

const scenes = [
  {
    label: 'Rangkaian Bunga',
    position: '0% 50%',
  },
  {
    label: 'Toko Floragate',
    position: '50% 50%',
  },
  {
    label: 'Tugu Malang',
    position: '100% 50%',
  },
];

const panoramaPanels = [
  { ...scenes[2], realIndex: 2, clone: true },
  { ...scenes[0], realIndex: 0, clone: false },
  { ...scenes[1], realIndex: 1, clone: false },
  { ...scenes[2], realIndex: 2, clone: false },
  { ...scenes[0], realIndex: 0, clone: true },
];
---

<section class="hero-cinematic" id="hero-banner" aria-label="Hero Banner Floragate">
  <div class="hero-mobile-bg" aria-hidden="true">
    <img
      src={mobileHeroImage}
      alt=""
      width="1920"
      height="1080"
      loading="eager"
      class="hero-mobile-img"
    />
  </div>

  <div class="hero-panorama-viewport" id="hero-panorama-viewport" aria-roledescription="carousel" aria-label="Panorama Floragate">
    <div class="hero-panorama-track" id="hero-panorama-track">
      {panoramaPanels.map((panel, index) => (
        <div
          class={`hero-panorama-panel ${panel.clone ? 'is-clone' : ''}`}
          data-real-index={panel.realIndex}
          data-track-index={index}
          aria-label={panel.label}
          role="group"
          style={`--panel-position: ${panel.position}; background-image: url('${panoramaImage}');`}
        ></div>
      ))}
    </div>
  </div>

  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="hero-grain" aria-hidden="true"></div>
  <div class="hero-vignette" aria-hidden="true"></div>

  <div class="hero-content-shell hero-center-content" id="hero-center-content">
    <div class="hero-copy">
      <div class="hero-top-badge" id="hero-top-badge">
        <svg class="hero-top-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657 13.414 20.9a1.998 1.998 0 0 1-2.827 0l-4.244-4.243a8 8 0 1 1 11.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
        </svg>
        <span>FLORIST TERMURAH DAN TERPERCAYA DI KOTA MALANG</span>
      </div>

      <h1 class="hero-main-heading" id="hero-main-heading">
        <span class="hero-main-line" id="hero-line-1">Karangan Bunga</span>
        <span class="hero-main-line hero-main-heading-accent hero-main-line--accent" id="hero-line-2">Premium</span>
        <span class="hero-main-line" id="hero-line-3">untuk Setiap Momen</span>
      </h1>

      
      <div class="hero-separator" id="hero-separator" aria-hidden="true">
        <span class="hero-separator-line"></span>
        <svg class="hero-separator-icon" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 3.5c1.1 2.7 2.8 4.4 5.5 5.5-2.7 1.1-4.4 2.8-5.5 5.5-1.1-2.7-2.8-4.4-5.5-5.5 2.7-1.1 4.4-2.8 5.5-5.5ZM5.2 14.8c.5 1.1 1.2 1.8 2.3 2.3-1.1.5-1.8 1.2-2.3 2.3-.5-1.1-1.2-1.8-2.3-2.3 1.1-.5 1.8-1.2 2.3-2.3Zm13.6 0c.5 1.1 1.2 1.8 2.3 2.3-1.1.5-1.8 1.2-2.3 2.3-.5-1.1-1.2-1.8-2.3-2.3 1.1-.5 1.8-1.2 2.3-2.3Z"/>
        </svg>
        <span class="hero-separator-line"></span>
      </div>
      <p class="hero-main-sub" id="hero-main-sub">
        <span class="hero-sub-line">Rangkaian bunga segar terbaik untuk setiap momen spesial Anda.</span>
        <span class="hero-sub-line">Dikerjakan oleh florist profesional dengan kualitas premium dan</span>
        <span class="hero-sub-line">pengiriman cepat ke seluruh <strong>Malang Raya</strong>.</span>
      </p>

      <div class="hero-cta-row" id="hero-cta-row">
        <a href="/katalog/" class="hero-btn hero-btn--gold">
          <span>Lihat Katalog</span>
          <svg class="hero-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0-4 4m4-4H3"/>
          </svg>
        </a>

        <a
          href={`https://wa.me/${WHATSAPP_NUMBER}?text=Halo%20Floragate,%20saya%20ingin%20pesan%20bunga%20di%20Malang.`}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-btn hero-btn--outline"
        >
          <svg class="hero-btn-wa" viewBox="0 0 24 24" fill="currentColor">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.965C16.588 2.02 14.12 1.022 11.5 1.022c-5.438 0-9.863 4.372-9.867 9.802-.001 1.73.473 3.42 1.37 4.947l-.994 3.63 3.734-.967c1.554.84 3.123 1.282 4.304 1.282zm11.304-6.858c-.31-.155-1.838-.895-2.122-.997-.284-.102-.49-.153-.696.155-.205.308-.796.997-.975 1.199-.179.203-.359.227-.669.073-.31-.155-1.31-.476-2.494-1.516-.922-.811-1.545-1.812-1.725-2.12-.179-.31-.018-.478.137-.631.14-.139.31-.359.464-.539.155-.179.206-.308.31-.513.102-.206.051-.385-.026-.539-.077-.154-.696-1.649-.953-2.263-.25-.596-.503-.515-.69-.525l-.59-.01c-.206 0-.54.077-.822.385-.282.308-1.079 1.052-1.079 2.565 0 1.513 1.103 2.977 1.257 3.182.155.206 2.17 3.267 5.257 4.569.735.31 1.307.495 1.753.634.739.231 1.412.197 1.944.119.593-.087 1.838-.739 2.095-1.453.258-.713.258-1.325.18-1.453-.077-.128-.283-.205-.593-.36z"/>
          </svg>
          <span>Pesan via WhatsApp</span>
        </a>
      </div>

      <div class="hero-stats-bar" id="hero-stats-bar">
        <div class="hero-stat-item">
          <svg class="hero-stat-icon-usp" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2a3 3 0 0 1 3 3c0 1.05-.54 1.97-1.35 2.5a5.96 5.96 0 0 1 2.5 1.35c.53-.81 1.45-1.35 2.5-1.35a3 3 0 1 1 0 6c-1.05 0-1.97-.54-2.5-1.35a5.96 5.96 0 0 1-1.35 2.5c.81.53 1.35 1.45 1.35 2.5a3 3 0 1 1-6 0c0-1.05.54-1.97 1.35-2.5a5.96 5.96 0 0 1-2.5-1.35c-.53.81-1.45 1.35-2.5 1.35a3 3 0 1 1 0-6c1.05 0 1.97.54 2.5 1.35a5.96 5.96 0 0 1 1.35-2.5C9.54 6.97 9 6.05 9 5a3 3 0 0 1 3-3zm0 8.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3z"/>
          </svg>
          <div class="hero-stat-text">
            <span class="hero-stat-title">Bunga Segar</span>
            <span class="hero-stat-sub-text">Kualitas Terbaik</span>
          </div>
        </div>
        <div class="hero-stat-sep"></div>
        <div class="hero-stat-item">
          <svg class="hero-stat-icon-usp" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM19 17a2 2 0 1 1-4 0 2 2 0 0 1 4 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v10m18 0v-6a1 1 0 0 0-1-1h-7m8 7h-8"/>
          </svg>
          <div class="hero-stat-text">
            <div class="hero-stat-title-row">
              <span class="hero-stat-num" data-target="3">0</span>
              <span class="hero-stat-unit">Jam</span>
              <span class="hero-stat-title-inline">Proses</span>
            </div>
            <span class="hero-stat-sub-text">Pengiriman Cepat</span>
          </div>
        </div>
        <div class="hero-stat-sep"></div>
        <div class="hero-stat-item">
          <svg class="hero-stat-icon-usp" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m9 12 2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          <div class="hero-stat-text">
            <div class="hero-stat-title-row">
              <span class="hero-stat-num" data-target="500">0</span>
              <span class="hero-stat-unit">+</span>
              <span class="hero-stat-title-inline">Terpercaya</span>
            </div>
            <span class="hero-stat-sub-text">Pesanan Selesai</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-desktop-controls" aria-hidden="false">
    <button class="hero-arrow hero-arrow--left" id="hero-arrow-left" type="button" aria-label="Scene sebelumnya">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19 8 12l7-7"/>
      </svg>
    </button>
    <button class="hero-arrow hero-arrow--right" id="hero-arrow-right" type="button" aria-label="Scene berikutnya">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
        <path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7"/>
      </svg>
    </button>
  </div>

  <div class="hero-indicators" id="hero-indicators" aria-label="Pilih scene hero">
    {scenes.map((scene, index) => (
      <button
        class={`hero-indicator ${index === 0 ? 'hero-indicator--active' : ''}`}
        type="button"
        data-slide={index}
        aria-label={`Tampilkan ${scene.label}`}
        aria-current={index === 0 ? 'true' : 'false'}
      >
        <span class="hero-indicator-fill"></span>
        <span class="hero-indicator-label">{scene.label}</span>
      </button>
    ))}
  </div>

  <div class="hero-fraction" id="hero-fraction" aria-hidden="true">
    <span class="hero-fraction-current" id="hero-fraction-current">01</span>
    <span class="hero-fraction-divider">/</span>
    <span class="hero-fraction-total">03</span>
      <span class="hero-fraction-bar"><span class="hero-fraction-bar-fill" id="hero-fraction-bar-fill"></span></span>
  </div>

  <div class="hero-scroll-hint" id="hero-scroll-hint" aria-hidden="true">
    <div class="hero-scroll-mouse"><div class="hero-scroll-wheel"></div></div>
    <span>Scroll</span>
  </div>

  <div class="hero-divider" aria-hidden="true">
    <svg viewBox="0 0 1440 120" fill="none" preserveAspectRatio="none">
      <path d="M0 120 L0 60 Q360 0 720 40 T1440 20 L1440 120Z" fill="var(--color-accent-bg)"/>
    </svg>
  </div>
</section>

<style>
  .hero-cinematic {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 640px;
    overflow: hidden;
    isolation: isolate;
    color: #f7f4ef;
    background: #10150d;
  }

  .hero-mobile-bg,
  .hero-panorama-viewport {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  .hero-mobile-img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .hero-panorama-viewport {
    display: none;
    touch-action: pan-y;
    cursor: grab;
  }

  .hero-panorama-viewport.is-dragging {
    cursor: grabbing;
  }

  .hero-panorama-track {
    display: flex;
    width: 500%;
    height: 100%;
    transform: translate3d(-20%, 0, 0);
    will-change: transform;
  }

  .hero-panorama-panel {
    flex: 0 0 20%;
    width: 20%;
    height: 100%;
    background-repeat: no-repeat;
    background-size: 300% 100%;
    background-position: var(--panel-position);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(12, 17, 10, 0.42) 0%, rgba(12, 17, 10, 0.78) 100%),
      linear-gradient(90deg, rgba(12, 17, 10, 0.9) 0%, rgba(12, 17, 10, 0.64) 58%, rgba(12, 17, 10, 0.32) 100%);
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    box-shadow: inset 0 0 120px rgba(0, 0, 0, 0.42);
  }

  .hero-content-shell {
    position: relative;
    z-index: 5;
    display: flex;
    align-items: center;
    width: min(100%, 1280px);
    height: 100%;
    margin: 0 auto;
    padding: 5.5rem 1.25rem 7rem;
    box-sizing: border-box;
  }

  .hero-copy {
    width: min(100%, 620px);
    text-align: center;
  }

  .hero-top-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    max-width: 100%;
    gap: 0.5rem;
    padding: 0.46rem 0.9rem;
    border: 1px solid rgba(214, 194, 156, 0.32);
    border-radius: 999px;
    color: var(--color-secondary-light);
    background: rgba(16, 21, 13, 0.48);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    line-height: 1.35;
    text-transform: uppercase;
    animation: heroRise 0.7s 0.15s both cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-top-badge-icon {
    width: 14px;
    height: 14px;
    flex: 0 0 auto;
  }

  .hero-main-heading {
    margin: 1.05rem 0 0;
    font-family: var(--font-serif), Georgia, serif;
    font-size: clamp(2.35rem, 10.5vw, 4.25rem);
    font-weight: 800;
    line-height: 1.06;
    color: #f7f4ef;
    text-shadow: 0 5px 34px rgba(0, 0, 0, 0.52);
  }

  .hero-main-heading span {
    display: block;
    animation: heroRise 0.75s both cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-main-heading span:nth-child(1) {
    animation-delay: 0.28s;
  }

  .hero-main-heading span:nth-child(2) {
    animation-delay: 0.4s;
  }

  .hero-main-heading span:nth-child(3) {
    animation-delay: 0.52s;
  }

  .hero-main-heading-accent {
    color: var(--color-secondary-light);
    font-style: italic;
  }

  .hero-main-sub {
    max-width: 590px;
    margin: 1.05rem auto 0;
    color: rgba(247, 244, 239, 0.76);
    font-size: clamp(0.92rem, 3.7vw, 1.03rem);
    line-height: 1.78;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.36);
    animation: heroRise 0.75s 0.66s both cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
    margin-top: 1.55rem;
    animation: heroRise 0.75s 0.78s both cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.58rem;
    min-height: 48px;
    padding: 0.9rem 1.45rem;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.86rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0.01em;
    transition:
      transform 0.28s ease,
      border-color 0.28s ease,
      background-color 0.28s ease,
      box-shadow 0.28s ease;
  }

  .hero-btn--gold {
    color: #14180f;
    background: linear-gradient(135deg, var(--color-secondary-light) 0%, var(--color-secondary) 100%);
    box-shadow: 0 16px 36px rgba(9, 13, 8, 0.26);
  }

  .hero-btn--outline {
    color: #f7f4ef;
    border: 1px solid rgba(247, 244, 239, 0.28);
    background: rgba(247, 244, 239, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .hero-btn:hover,
  .hero-btn:focus-visible {
    transform: translateY(-2px);
  }

  .hero-btn--gold:hover,
  .hero-btn--gold:focus-visible {
    box-shadow: 0 20px 44px rgba(191, 167, 122, 0.22);
  }

  .hero-btn--outline:hover,
  .hero-btn--outline:focus-visible {
    border-color: rgba(214, 194, 156, 0.62);
    background: rgba(191, 167, 122, 0.15);
  }

  .hero-btn-icon,
  .hero-btn-wa {
    width: 17px;
    height: 17px;
    flex: 0 0 auto;
  }

  .hero-trust-list {
    display: grid;
    gap: 0.7rem;
    width: min(100%, 430px);
    margin: 1.5rem auto 0;
    animation: heroRise 0.75s 0.9s both cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-trust-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
    color: rgba(247, 244, 239, 0.76);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.35;
    text-align: left;
  }

  .hero-trust-item strong {
    color: #f7f4ef;
    font-weight: 800;
  }

  .hero-trust-icon {
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
    color: var(--color-secondary-light);
  }

  .hero-desktop-controls,
  .hero-indicators,
  .hero-fraction {
    display: none;
  }

  @keyframes heroRise {
    from {
      opacity: 0;
      transform: translateY(22px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 480px) {
    .hero-cinematic {
      min-height: 700px;
    }

    .hero-content-shell {
      padding-inline: 1rem;
    }

    .hero-top-badge {
      font-size: 0.56rem;
      letter-spacing: 0.08em;
    }

    .hero-cta-row {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .hero-btn {
      width: 100%;
    }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .hero-cinematic {
      min-height: 760px;
    }
  }

  @media (min-width: 1024px) {
    .hero-cinematic {
      height: calc(100vh - 56px);
      height: calc(100dvh - 56px);
      min-height: 760px;
      max-height: none;
    }

    .hero-mobile-bg {
      display: none;
    }

    .hero-panorama-viewport {
      display: block;
    }

    .hero-overlay {
      background:
        linear-gradient(90deg, rgba(9, 14, 7, 0.92) 0%, rgba(9, 14, 7, 0.8) 34%, rgba(9, 14, 7, 0.34) 67%, rgba(9, 14, 7, 0.16) 100%),
        linear-gradient(180deg, rgba(9, 14, 7, 0.25) 0%, rgba(9, 14, 7, 0.38) 54%, rgba(9, 14, 7, 0.7) 100%);
    }

    .hero-content-shell {
      justify-content: flex-start;
      padding: 4.25rem 4.5rem 6rem;
    }

    .hero-copy {
      text-align: left;
    }

    .hero-main-heading {
      font-size: clamp(4rem, 5.4vw, 6.55rem);
      line-height: 1.01;
    }

    .hero-main-sub {
      margin-left: 0;
      margin-right: 0;
      font-size: clamp(0.98rem, 1.2vw, 1.12rem);
    }

    .hero-cta-row {
      justify-content: flex-start;
    }

    .hero-trust-list {
      width: fit-content;
      max-width: 100%;
      margin-left: 0;
      grid-template-columns: repeat(3, auto);
      gap: 1.15rem;
      padding: 0.85rem 1rem;
      border: 1px solid rgba(214, 194, 156, 0.18);
      border-radius: 8px;
      background: rgba(9, 14, 7, 0.38);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    .hero-trust-item {
      max-width: 180px;
      font-size: 0.76rem;
    }

    .hero-desktop-controls {
      display: block;
    }

    .hero-arrow {
      position: absolute;
      top: 50%;
      z-index: 8;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      border: 1px solid rgba(247, 244, 239, 0.22);
      border-radius: 999px;
      color: #f7f4ef;
      background: rgba(9, 14, 7, 0.38);
      box-shadow: 0 16px 36px rgba(0, 0, 0, 0.22);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      transform: translateY(-50%);
      cursor: pointer;
      transition:
        transform 0.24s ease,
        color 0.24s ease,
        background-color 0.24s ease,
        border-color 0.24s ease;
    }

    .hero-arrow:hover,
    .hero-arrow:focus-visible {
      color: #14180f;
      border-color: var(--color-secondary-light);
      background: var(--color-secondary-light);
      transform: translateY(-50%) scale(1.06);
    }

    .hero-arrow svg {
      width: 21px;
      height: 21px;
    }

    .hero-arrow--left {
      left: 2rem;
    }


    }

    function runIntroAnimation() {
      revealElement('#hero-top-badge', { delay: 400, duration: 700 });

      document.querySelectorAll('.hero-main-line').forEach(function(el, index) {
        revealElement(el, { delay: 700 + index * 180, duration: 900 });
      });

      revealElement('#hero-separator', { delay: 1180, duration: 500 });
      revealElement('#hero-main-sub', { delay: 1320, duration: 700 });
      revealElement('#hero-cta-row', { delay: 1540, duration: 600 });
      revealElement('#hero-stats-bar', { delay: 1720, duration: 700 });

      ['#hero-indicators', '#hero-fraction', '#hero-arrow-left', '#hero-arrow-right'].forEach(function(selector) {
        revealElement(selector, { delay: 2000, duration: 600, transform: null });
      });

      revealElement('#hero-scroll-hint', { delay: 2180, duration: 500, opacity: 0.6, transform: null });
      window.setTimeout(animateCounters, 2100);
      window.setTimeout(function() {
        hasIntroRun = true;
        startAutoplay();
      }, 2600);
    }
    function panelOffset(panelIndex) {
      return -panelIndex * (100 / panelCount);
    }

    function setPanel(panelIndex, animate) {
      var duration = reduceMotionQuery.matches ? 0 : 760;
      track.style.transition = animate && duration
        ? 'transform ' + duration + 'ms cubic-bezier(0.25, 1, 0.5, 1)'
        : 'none';
      track.style.transform = 'translate3d(' + panelOffset(panelIndex) + '%, 0, 0)';
    }

    function setPanelPixels(pixelOffset) {
      track.style.transition = 'none';
      track.style.transform = 'translate3d(' + pixelOffset + 'px, 0, 0)';
    }

    function updateUI(sceneIndex) {
      currentScene = sceneIndex;

      indicators.forEach(function(indicator, index) {
        var active = index === sceneIndex;
        indicator.classList.toggle('hero-indicator--active', active);
        indicator.setAttribute('aria-current', active ? 'true' : 'false');
      });

      if (fractionCurrent) {
        fractionCurrent.textContent = '0' + (sceneIndex + 1);
      }

      if (fractionBarFill) {
        fractionBarFill.style.width = ((sceneIndex + 1) / sceneCount) * 100 + '%';
      }
    }

    function finishInfiniteJump() {
      if (currentPanel === 4) {
        currentPanel = 1;
        setPanel(currentPanel, false);
      }

      if (currentPanel === 0) {
        currentPanel = 3;
        setPanel(currentPanel, false);
      }

      isTransitioning = false;
    }

    function goNext() {
      if (!desktopActive || isTransitioning) return;

      isTransitioning = true;
      currentPanel += 1;
      updateUI((currentScene + 1) % sceneCount);
      setPanel(currentPanel, true);

      if (reduceMotionQuery.matches) {
        finishInfiniteJump();
      }
    }

    function goPrev() {
      if (!desktopActive || isTransitioning) return;

      isTransitioning = true;
      currentPanel -= 1;
      updateUI((currentScene - 1 + sceneCount) % sceneCount);
      setPanel(currentPanel, true);

      if (reduceMotionQuery.matches) {
        finishInfiniteJump();
      }
    }

    function goToScene(targetScene) {
      if (!desktopActive || targetScene === currentScene || isTransitioning) return;

      var forwardDistance = (targetScene - currentScene + sceneCount) % sceneCount;
      var backwardDistance = (currentScene - targetScene + sceneCount) % sceneCount;

      if (forwardDistance <= backwardDistance) {
        goNext();
      } else {
        goPrev();
      }
    }

    function stopAutoplay() {
      if (autoplayTimer) {
        window.clearInterval(autoplayTimer);
        autoplayTimer = null;
      }
    }

    function startAutoplay() {
      stopAutoplay();
      if (!desktopActive || reduceMotionQuery.matches) return;
      autoplayTimer = window.setInterval(goNext, autoplayDelay);
    }

    function resetForMode() {
      desktopActive = desktopQuery.matches;
      stopAutoplay();
      isTransitioning = false;
      dragState = null;
      viewport.classList.remove('is-dragging');

      if (desktopActive) {
        currentPanel = currentScene + 1;
        setPanel(currentPanel, false);
        if (hasIntroRun) startAutoplay();
      } else {
        track.style.transition = 'none';
        track.style.transform = 'translate3d(-20%, 0, 0)';
      }
    }

    track.addEventListener('transitionend', function(event) {
      if (event.propertyName !== 'transform') return;
      finishInfiniteJump();
    });

    if (btnNext) {
      btnNext.addEventListener('click', function() {
        goNext();
        startAutoplay();
      });
    }

    if (btnPrev) {
      btnPrev.addEventListener('click', function() {
        goPrev();
        startAutoplay();
      });
    }

    indicators.forEach(function(indicator, index) {
      indicator.addEventListener('click', function() {
        goToScene(index);
        startAutoplay();
      });
    });

    hero.addEventListener('mouseenter', stopAutoplay);
    hero.addEventListener('mouseleave', startAutoplay);
    hero.addEventListener('focusin', stopAutoplay);
    hero.addEventListener('focusout', startAutoplay);

    viewport.addEventListener('pointerdown', function(event) {
      if (!desktopActive || isTransitioning || event.button !== 0) return;

      stopAutoplay();
      dragState = {
        startX: event.clientX,
        currentX: event.clientX,
        baseOffset: -currentPanel * viewport.clientWidth,
        pointerId: event.pointerId,
      };
      viewport.classList.add('is-dragging');
      viewport.setPointerCapture(event.pointerId);
    });

    viewport.addEventListener('pointermove', function(event) {
      if (!dragState || event.pointerId !== dragState.pointerId) return;

      dragState.currentX = event.clientX;
      var delta = dragState.currentX - dragState.startX;
      setPanelPixels(dragState.baseOffset + delta);
    });

    function endDrag(event) {
      if (!dragState || event.pointerId !== dragState.pointerId) return;

      var delta = dragState.currentX - dragState.startX;
      var threshold = Math.min(160, viewport.clientWidth * 0.12);

      viewport.classList.remove('is-dragging');
      dragState = null;

      if (Math.abs(delta) >= threshold) {
        if (delta < 0) {
          goNext();
        } else {
          goPrev();
        }
      } else {
        setPanel(currentPanel, true);
      }

      startAutoplay();
    }

    viewport.addEventListener('pointerup', endDrag);
    viewport.addEventListener('pointercancel', endDrag);

    desktopQuery.addEventListener('change', resetForMode);
    reduceMotionQuery.addEventListener('change', resetForMode);
    window.addEventListener('resize', function() {
      if (!desktopActive || dragState) return;
      setPanel(currentPanel, false);
    }, { passive: true });
    function easeOutCubic(t) {
      return 1 - Math.pow(1 - t, 3);
    }

    function animateCounters() {
      var counters = document.querySelectorAll('.hero-stat-num[data-target]');
      counters.forEach(function(el) {
        var target = parseInt(el.getAttribute('data-target') || '0', 10);
        var duration = target > 100 ? 2000 : 1000;
        var start = performance.now();

        function tick(now) {
          var progress = Math.min((now - start) / duration, 1);
          el.textContent = String(Math.round(easeOutCubic(progress) * target));
          if (progress < 1) window.requestAnimationFrame(tick);
        }

        window.requestAnimationFrame(tick);
      });
    }

    var scrollHint = document.getElementById('hero-scroll-hint');
    if (scrollHint) {
      var hasScrolled = false;
      window.addEventListener('scroll', function() {
        if (!hasScrolled && window.scrollY > 80) {
          hasScrolled = true;
          scrollHint.style.transition = 'opacity 400ms ease';
          scrollHint.style.opacity = '0';
        }
      }, { passive: true });
    }
    updateUI(0);
    resetForMode();
    runIntroAnimation();
  });
</script>







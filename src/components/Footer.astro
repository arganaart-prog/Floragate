---
// Footer.astro
import { CATEGORIES } from '../data/products';
import { WHATSAPP_NUMBER, WHATSAPP_LABEL, INSTAGRAM_URL, INSTAGRAM_HANDLE } from '../data/constants';
import { withBase } from '../utils/paths';

const currentYear = new Date().getFullYear();

const infoLinks = [
  { label: 'Beranda', href: '/' },
  { label: 'Katalog Produk', href: '/katalog/' },
  { label: 'Cara Pesan', href: '/cara-pesan/' },
  { label: 'Tentang Kami', href: '/tentang/' },
  { label: 'Hubungi Kontak', href: '/kontak/' },
];

const paymentMethods = [
  { label: 'BCA', image: '/images/Payment/bca.svg' },
  { label: 'BNI', image: '/images/Payment/bni.svg' },
  { label: 'BRI', image: '/images/Payment/bri.svg' },
  { label: 'Mandiri', image: '/images/Payment/mandiri.svg' },
  { label: 'OVO', image: '/images/Payment/ovo.svg' },
  { label: 'ShopeePay', image: '/images/Payment/shopepay.png' },
];
---

<footer
  class="relative overflow-hidden text-white pt-14 pb-10"
  style="background: radial-gradient(circle at 8% 0%, rgba(191, 167, 122, 0.34), transparent 28%), linear-gradient(135deg, #3F4B37 0%, #55654B 50%, #6A7B5F 100%);"
>
  <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(255,255,255,0.08),transparent_34%,rgba(191,167,122,0.12))]" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 lg:gap-6 mb-10">
      <!-- Brand -->
      <div class="md:pr-4 lg:pr-8">
        <a href={withBase('/')} class="flex items-center gap-4 mb-5 group no-underline">
          <span class="flex h-20 w-20 shrink-0 items-center justify-center overflow-hidden rounded-lg bg-white shadow-[0_14px_30px_rgba(15,23,42,0.18)]">
            <img
              src={withBase('/images/logo/logo%20Floragate%201.png')}
              alt="Logo Floragate"
              class="h-[4.65rem] w-auto object-contain transition-opacity duration-300 group-hover:opacity-90"
              width={96}
              height={64}
              loading="lazy"
              decoding="async"
            />
          </span>
          <span class="min-w-0">
            <span class="block font-serif text-3xl font-bold leading-tight text-white">Floragate</span>
            <span class="block text-base sm:text-lg text-white/82 leading-tight">The Gateway to Meaningful Moments</span>
          </span>
        </a>

        <p class="max-w-sm text-base leading-relaxed text-white/88 mb-6">
          Layanan pemesanan bunga premium di Malang Raya dan Batu dengan rangkaian segar, elegan, dan pengerjaan cepat untuk setiap momen penting.
        </p>

        <div class="flex items-center gap-3">
          <a
            href={INSTAGRAM_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-12 w-12 items-center justify-center rounded-full bg-white/12 text-white shadow-sm transition-all duration-200 hover:bg-white/22"
            aria-label="Instagram Floragate"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="4" y="4" width="16" height="16" rx="5" />
              <circle cx="12" cy="12" r="3.4" />
              <path stroke-linecap="round" d="M17.5 6.8h.01" />
            </svg>
          </a>
          <a
            href={`https://wa.me/${WHATSAPP_NUMBER}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-12 w-12 items-center justify-center rounded-full bg-white/12 text-white shadow-sm transition-all duration-200 hover:bg-white/22"
            aria-label="WhatsApp Floragate"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.5 19.2l.9-3A7.6 7.6 0 1 1 9 18.6l-3.5.6z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.4 8.6c.4 2.8 2.1 4.5 5 5" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Categories -->
      <div class="lg:ml-12">
        <h3 class="text-xl font-bold text-white mb-3">Kategori Produk</h3>
        <ul class="space-y-1.5 text-lg">
          {CATEGORIES.slice(0, 6).map((category) => (
            <li>
              <a href={withBase(`/kategori/${category.slug}/`)} class="text-white/78 hover:text-white transition-colors duration-200 font-medium leading-normal">
                {category.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Information -->
      <div class="lg:ml-8">
        <h3 class="text-xl font-bold text-white mb-3">Informasi</h3>
        <ul class="space-y-1.5 text-lg">
          {infoLinks.map((link) => (
            <li>
              <a href={withBase(link.href)} class="text-white/78 hover:text-white transition-colors duration-200 font-medium leading-normal">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact + Payment -->
      <div>
        <h3 class="text-xl font-bold text-white mb-3">Kontak Kami</h3>

        <p class="text-base text-white/88 leading-normal mb-3">
          Area layanan Floragate: Kota Malang, Kabupaten Malang, dan Kota Batu.
        </p>

        <p class="text-base flex items-center gap-2 text-white/88 leading-normal">
          <svg class="h-4 w-4 shrink-0 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 10.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 20l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 1 1 17 0z" />
          </svg>
          <a href={`https://wa.me/${WHATSAPP_NUMBER}`} target="_blank" rel="noopener noreferrer" class="hover:text-secondary transition-colors duration-200">{WHATSAPP_LABEL}</a>
        </p>
        <p class="text-base flex items-center gap-2 text-white/88 leading-normal mb-3">
          <svg class="h-4 w-4 shrink-0 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="4" y="4" width="16" height="16" rx="5" />
            <circle cx="12" cy="12" r="3" />
          </svg>
          <a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer" class="hover:text-secondary transition-colors duration-200">{INSTAGRAM_HANDLE}</a>
        </p>

        <div class="pt-3 border-t border-white/20 mb-4">
          <p class="text-base font-semibold text-white">Buka Setiap Hari</p>
          <p class="text-sm text-white/78">09.00 - 23.00 WIB</p>
          <p class="text-xs text-white/60 mt-1">Di luar jam tersebut slow respon.</p>
        </div>

        <h4 class="text-base font-semibold text-white mb-2">Metode Pembayaran</h4>
        <div class="flex flex-wrap gap-2">
          {paymentMethods.map((method) => (
            <img
              src={withBase(method.image)}
              alt={method.label}
              class="h-9 w-14 rounded-md bg-white p-1 object-contain shadow-sm"
              width={56}
              height={36}
              loading="lazy"
              decoding="async"
            />
          ))}
        </div>
      </div>
    </div>

    <div class="pt-4 border-t border-white/20 text-center">
      <p class="text-sm text-white/68">&copy; {currentYear} Floragate. All Rights Reserved.</p>
    </div>
  </div>
</footer>


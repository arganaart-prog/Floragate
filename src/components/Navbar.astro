---
// Navbar.astro
import { WHATSAPP_NUMBER } from '../data/constants';
import { CATEGORIES } from '../data/products';
import { stripBase, withBase } from '../utils/paths';

const navItems = [
  { href: '/', label: 'Beranda' },
  { href: '/katalog/', label: 'Katalog', hasDropdown: true },
  { href: '/cara-pesan/', label: 'Cara Pesan' },
  { href: '/tentang/', label: 'Tentang Kami' },
  { href: '/kontak/', label: 'Kontak' }
];

const currentPath = stripBase(Astro.url.pathname);
const isMobileHome = currentPath === '/';
const isMobileKatalog = currentPath.startsWith('/katalog/') || currentPath.startsWith('/kategori/') || currentPath.startsWith('/produk/');
const isMobileCaraPesan = currentPath.startsWith('/cara-pesan/');
const isMobileTentang = currentPath.startsWith('/tentang/');
---

<!-- ============================================= -->
<!-- DESKTOP NAVBAR (Two rows, shown on md and up) -->
<!-- ============================================= -->

<!-- Row 1: Brand, Search, & WhatsApp Button (Primary Theme Green) -->
<div class="relative z-50 hidden md:block bg-primary border-b border-white/10 px-4 lg:px-8">
      <div class="max-w-7xl mx-auto flex items-center justify-between h-24 md:h-28">
        
        <!-- Logo & Brand Name -->
        <div class="flex items-center">
          <div class="flex-shrink-0 flex items-center relative h-24 md:h-28">
            <!-- Absolute shield hanging down -->
            <div class="absolute left-0 top-0 w-22 sm:w-24 md:w-28 h-26 sm:h-28 md:h-32 z-20">
              <a href={withBase('/')} class="block w-full h-full relative group" id="logo-shield">
                <!-- SVG Shield Background with warm cream color #FAF7ED and gold lines -->
                <svg class="absolute inset-0 w-full h-full drop-shadow-[0_4px_8px_rgba(0,0,0,0.15)] transition-transform duration-300 group-hover:scale-105" viewBox="0 0 100 115" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0 0 H100 V55 C100 88 50 115 50 115 C50 115 0 88 0 55 Z" fill="#FAF7ED"/>
                </svg>
                <!-- Brand Logo Centered -->
                <div class="absolute inset-0 flex items-center justify-center pb-3 md:pb-4">
                  <img 
                    src={withBase('/images/logo/logo%20Floragate%201.png')} 
                    alt="Logo Floragate" 
                    class="h-14 sm:h-16 md:h-20 w-auto scale-[1.15] object-contain transition-transform duration-300 group-hover:scale-125"
                    width={64}
                    height={62}
                    loading="eager"
                  />
                </div>
              </a>
            </div>
            <!-- Spacer for logo layout so the brand text starts after the logo -->
            <div class="w-22 sm:w-24 md:w-28 flex-shrink-0"></div>
          </div>

          <!-- Brand Text -->
          <div class="ml-4 md:ml-6 flex flex-col justify-center text-white select-none">
            <span class="font-serif text-2xl sm:text-3xl md:text-4xl font-bold tracking-wide leading-none">Floragate</span>
            <span class="text-[11px] sm:text-xs md:text-sm text-white/80 font-medium font-sans mt-2 tracking-wide leading-none">The Gateway to Meaningful Moments</span>
          </div>
        </div>

        <!-- Search Bar (Pill-shaped, aligned to the right) -->
        <div class="w-full max-w-[280px] lg:max-w-[340px] ml-auto mr-6 lg:mr-8">
          <form action={withBase('/katalog/')} method="GET" class="relative w-full">
            <input 
              type="text" 
              name="search"
              maxlength="80"
              autocomplete="off"
              placeholder="Cari produk bunga..." 
              class="search-input-field w-full px-5 py-3 pr-12 rounded-full border border-white/20 bg-white/10 text-white text-sm placeholder-white/60 focus:outline-none focus:ring-2 focus:ring-secondary/50 focus:border-secondary focus:bg-white/20 transition-all"
            />
            <button type="submit" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-secondary transition-colors cursor-pointer">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
          </form>
        </div>

        <!-- WhatsApp Call to Action (Gold Button) -->
        <div class="flex-shrink-0">
          <a 
            href={`https://wa.me/${WHATSAPP_NUMBER}?text=Halo%20Floragate,%20saya%20ingin%20tanya%20mengenai%20layanan%20pemesanan%20bunga%20di%20Malang.`} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-secondary hover:bg-secondary-dark text-xs font-bold text-white transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5"
          >
            <svg class="h-4 w-4 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.965C16.588 2.02 14.12 1.022 11.5 1.022c-5.438 0-9.863 4.372-9.867 9.802-.001 1.73.473 3.42 1.37 4.947l-.994 3.63 3.734-.967c1.554.84 3.123 1.282 4.304 1.282zm11.304-6.858c-.31-.155-1.838-.895-2.122-.997-.284-.102-.49-.153-.696.155-.205.308-.796.997-.975 1.199-.179.203-.359.227-.669.073-.31-.155-1.31-.476-2.494-1.516-.922-.811-1.545-1.812-1.725-2.12-.179-.31-.018-.478.137-.631.14-.139.31-.359.464-.539.155-.179.206-.308.31-.513.102-.206.051-.385-.026-.539-.077-.154-.696-1.649-.953-2.263-.25-.596-.503-.515-.69-.525l-.59-.01c-.206 0-.54.077-.822.385-.282.308-1.079 1.052-1.079 2.565 0 1.513 1.103 2.977 1.257 3.182.155.206 2.17 3.267 5.257 4.569.735.31 1.307.495 1.753.634.739.231 1.412.197 1.944.119.593-.087 1.838-.739 2.095-1.453.258-.713.258-1.325.18-1.453-.077-.128-.283-.205-.593-.36z" />
            </svg>
            Order WhatsApp
          </a>
        </div>
        
      </div>
    </div>

<!-- Row 2: Centered Navigation Links (Primary Dark Theme Green - Sticky) -->
<div id="desktop-sticky-nav" class="relative z-40 hidden md:block bg-primary-dark px-4 shadow-md">
  <a href={withBase('/')} class="desktop-scroll-logo" aria-label="Floragate" tabindex="-1">
    <svg class="desktop-scroll-logo-shield" viewBox="0 0 100 115" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M0 0 H100 V55 C100 88 50 115 50 115 C50 115 0 88 0 55 Z" fill="#FAF7ED"/>
    </svg>
    <img
      src={withBase('/images/logo/logo%20Floragate%201.png')}
      alt=""
      class="desktop-scroll-logo-img"
      width={64}
      height={62}
      loading="eager"
    />
  </a>
      <div class="max-w-7xl mx-auto flex justify-center items-center h-14 relative">
        <nav class="flex items-center gap-10" id="desktop-nav">
          {navItems.map(item => {
            const isHome = item.href === '/' && currentPath === '/';
            const isSubpage = item.href !== '/' && (
              currentPath.startsWith(item.href) || 
              (item.href === '/katalog/' && (currentPath.startsWith('/kategori/') || currentPath.startsWith('/produk/')))
            );
            const isActive = isHome || isSubpage;
            
            if (item.hasDropdown) {
              return (
                <div class="relative group py-3" id="katalog-dropdown-trigger">
                  <a 
                    href={withBase(item.href)} 
                    class={`flex items-center gap-1.5 text-xs sm:text-sm font-semibold tracking-wide transition-colors ${isActive ? 'text-white border-b-2 border-secondary pb-1' : 'text-white/80 hover:text-secondary'}`}
                  >
                    {item.label}
                    <svg class="h-3.5 w-3.5 text-white/60 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </a>
                  
                  <!-- Dropdown Menu -->
                  <div class="absolute left-1/2 -translate-x-1/2 top-full w-64 bg-[#FAF7ED] rounded-md shadow-xl border border-soft-cream/30 py-2 opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200 z-50">
                    <div class="absolute -top-1.5 left-1/2 -translate-x-1/2 w-3 h-3 bg-[#FAF7ED] rotate-45 border-t border-l border-soft-cream/30"></div>
                    {CATEGORIES.map(category => (
                      <a 
                        href={withBase(`/kategori/${category.slug}/`)} 
                        class="block px-4 py-2.5 text-xs font-semibold text-slate-700 hover:text-primary hover:bg-primary/5 transition-colors"
                      >
                        {category.name}
                      </a>
                    ))}
                    <div class="border-t border-soft-cream/20 my-1"></div>
                    <a 
                      href={withBase('/katalog/')} 
                      class="block px-4 py-2.5 text-xs font-bold text-center text-secondary hover:text-secondary-dark hover:bg-secondary/5 transition-colors"
                    >
                      Lihat Semua Karangan Bunga ->
                    </a>
                  </div>
                </div>
              );
            }

            return (
              <a 
                href={withBase(item.href)} 
                class={`text-xs sm:text-sm font-semibold tracking-wide transition-colors py-3 ${isActive ? 'text-white border-b-2 border-secondary pb-1' : 'text-white/80 hover:text-secondary'}`}
              >
                {item.label}
              </a>
            );
          })}
        </nav>
      </div>
    </div>
<div id="desktop-nav-spacer" class="desktop-nav-spacer" aria-hidden="true"></div>

<!-- ============================================= -->
  <!-- MOBILE NAVBAR (One row, shown below md - Sticky) -->
  <!-- ============================================= -->
  <div class="fixed inset-x-0 top-0 z-[60] md:hidden bg-primary shadow-md">
    <div class="px-4">
    <div class="flex items-center justify-between h-20">
      
      <!-- Brand & Shield Logo Container -->
      <div class="flex items-center">
        <div class="flex-shrink-0 flex items-center relative h-20">
          <div class="absolute left-0 top-0 w-14 h-18 z-20">
            <a href={withBase('/')} class="block w-full h-full relative">
              <svg class="absolute inset-0 w-full h-full drop-shadow-[0_2px_4px_rgba(0,0,0,0.15)]" viewBox="0 0 100 115" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0 0 H100 V55 C100 88 50 115 50 115 C50 115 0 88 0 55 Z" fill="#FAF7ED"/>
              </svg>
              <div class="absolute inset-0 flex items-center justify-center pb-2.5">
                <img 
                  src={withBase('/images/logo/logo%20Floragate%201.png')} 
                  alt="Logo Floragate" 
                  class="h-10 w-auto scale-110 object-contain"
                  width={34}
                  height={33}
                  loading="eager"
                />
              </div>
            </a>
          </div>
          <!-- Spacer -->
          <div class="w-14 flex-shrink-0"></div>
        </div>

        <div class="ml-1.5 -translate-y-1.5 text-white flex flex-col justify-center select-none">
          <span class="font-serif text-lg font-bold tracking-wide leading-none">Floragate</span>
          <span class="text-[9px] sm:text-[10px] text-white/80 font-sans mt-1 leading-tight">The Gateway to Meaningful Moments</span>
        </div>
      </div>

      <!-- Quick Action Buttons -->
      <div class="flex items-center gap-2">
        <!-- WhatsApp Quick Icon -->
        <a 
          href={`https://wa.me/${WHATSAPP_NUMBER}?text=Halo%20Floragate,%20saya%20ingin%20tanya%20mengenai%20layanan%20pemesanan%20bunga%20di%20Malang.`} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="p-2.5 rounded-full bg-white text-primary hover:bg-slate-100 transition-colors shadow-sm"
          aria-label="Pesan via WhatsApp"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.965C16.588 2.02 14.12 1.022 11.5 1.022c-5.438 0-9.863 4.372-9.867 9.802-.001 1.73.473 3.42 1.37 4.947l-.994 3.63 3.734-.967c1.554.84 3.123 1.282 4.304 1.282zm11.304-6.858c-.31-.155-1.838-.895-2.122-.997-.284-.102-.49-.153-.696.155-.205.308-.796.997-.975 1.199-.179.203-.359.227-.669.073-.31-.155-1.31-.476-2.494-1.516-.922-.811-1.545-1.812-1.725-2.12-.179-.31-.018-.478.137-.631.14-.139.31-.359.464-.539.155-.179.206-.308.31-.513.102-.206.051-.385-.026-.539-.077-.154-.696-1.649-.953-2.263-.25-.596-.503-.515-.69-.525l-.59-.01c-.206 0-.54.077-.822.385-.282.308-1.079 1.052-1.079 2.565 0 1.513 1.103 2.977 1.257 3.182.155.206 2.17 3.267 5.257 4.569.735.31 1.307.495 1.753.634.739.231 1.412.197 1.944.119.593-.087 1.838-.739 2.095-1.453.258-.713.258-1.325.18-1.453-.077-.128-.283-.205-.593-.36z" />
          </svg>
        </a>

        <!-- Mobile Menu Button -->
        <button 
          id="mobile-menu-btn" 
          type="button" 
          class="inline-flex items-center justify-center p-2 rounded-md text-white/80 hover:text-white focus:outline-none"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Buka menu"
        >
          <span class="sr-only">Open main menu</span>
          <svg class="block h-6 w-6" id="menu-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="hidden h-6 w-6" id="close-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- MOBILE MENU DRAWER (Hidden by default, shown when toggled) -->
  <div class="hidden md:hidden fixed inset-0 z-[80] mobile-menu-shell" id="mobile-menu" aria-hidden="true">
    <button id="mobile-menu-backdrop" type="button" class="mobile-menu-backdrop absolute inset-0 bg-slate-900/35 backdrop-blur-[2px]" aria-label="Tutup menu"></button>
    <aside class="mobile-menu-panel relative flex h-full w-[82vw] max-w-[410px] flex-col bg-[#FAF7ED] px-5 py-7 shadow-2xl rounded-r-2xl select-none">
      <div class="flex items-start justify-between gap-4 px-1">
        <h2 class="font-serif text-[1.75rem] font-bold leading-none text-primary">Floragate Malang</h2>
        <button id="mobile-menu-close" type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-full text-[#555a50] hover:bg-primary/5 hover:text-primary" aria-label="Tutup menu">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6 6 18" />
          </svg>
        </button>
      </div>

      <nav class="mt-10 space-y-3" aria-label="Menu mobile Floragate">
        <a href={withBase('/')} class={`flex items-center gap-3.5 rounded-lg px-4 py-3.5 text-[1.35rem] font-medium transition-colors ${isMobileHome ? 'bg-[#ead9be] text-primary' : 'text-[#555a50] hover:bg-primary/5 hover:text-primary'}`}>
          <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1">
            <path stroke-linecap="round" stroke-linejoin="round" d="m3 10.5 9-7 9 7" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.5 9.5V20h5v-6h3v6h5V9.5" />
          </svg>
          <span>Home</span>
        </a>

        <a href={withBase('/katalog/')} class={`flex items-center gap-3.5 rounded-lg px-4 py-3.5 text-[1.35rem] font-medium transition-colors ${isMobileKatalog ? 'bg-[#ead9be] text-primary' : 'text-[#555a50] hover:bg-primary/5 hover:text-primary'}`}>
          <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM14 14h6v6h-6z" />
          </svg>
          <span>Katalog</span>
        </a>

        <a href={withBase('/#momen')} class="flex items-center gap-3.5 rounded-lg px-4 py-3.5 text-[1.35rem] font-medium text-[#555a50] transition-colors hover:bg-primary/5 hover:text-primary">
          <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3.5c.8 2.3 2.2 3.7 4.5 4.5-2.3.8-3.7 2.2-4.5 4.5-.8-2.3-2.2-3.7-4.5-4.5 2.3-.8 3.7-2.2 4.5-4.5Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.5 13.5c.45 1.2 1.2 1.95 2.4 2.4-1.2.45-1.95 1.2-2.4 2.4-.45-1.2-1.2-1.95-2.4-2.4 1.2-.45 1.95-1.2 2.4-2.4ZM18.5 14.5c.38 1 .98 1.62 2 2-.98.38-1.62 1-2 2-.38-1-.98-1.62-2-2 .98-.38 1.62-1 2-2Z" />
          </svg>
          <span>Momen</span>
        </a>

        <a href={withBase('/cara-pesan/')} class={`flex items-center gap-3.5 rounded-lg px-4 py-3.5 text-[1.35rem] font-medium transition-colors ${isMobileCaraPesan ? 'bg-[#ead9be] text-primary' : 'text-[#555a50] hover:bg-primary/5 hover:text-primary'}`}>
          <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9a2.35 2.35 0 1 1 3.45 2.08c-.86.5-1.2 1.06-1.2 1.92" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 16h.01" />
          </svg>
          <span>Cara Pesan</span>
        </a>

        <a href={withBase('/tentang/')} class={`flex items-center gap-3.5 rounded-lg px-4 py-3.5 text-[1.35rem] font-medium transition-colors ${isMobileTentang ? 'bg-[#ead9be] text-primary' : 'text-[#555a50] hover:bg-primary/5 hover:text-primary'}`}>
          <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 11v5" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8h.01" />
          </svg>
          <span>Tentang</span>
        </a>
      </nav>
    </aside>
  </div>
</div>
<div class="md:hidden h-20" aria-hidden="true"></div>
<style>
  .desktop-scroll-logo {
    display: none;
  }

  @media (min-width: 768px) {
    #desktop-sticky-nav.is-fixed .desktop-scroll-logo {
      position: absolute;
      top: -7rem;
      left: var(--desktop-scroll-logo-left, clamp(1.75rem, 4vw, 3.5rem));
      z-index: 80;
      display: block;
      width: 7rem;
      height: 8rem;
      pointer-events: none;
    }

    .desktop-scroll-logo-shield {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.18));
    }

    .desktop-scroll-logo-img {
      position: absolute;
      top: 43%;
      left: 50%;
      width: auto;
      height: 5rem;
      object-fit: contain;
      transform: translate(-50%, -50%) scale(1.12);
    }
  }
  .desktop-nav-spacer {
    display: none;
    height: 3.5rem;
  }

  #desktop-sticky-nav.is-fixed {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 70;
    overflow: visible;
  }

  @media (min-width: 768px) {
    .desktop-nav-spacer.is-active {
      display: block;
    }
  }
  .mobile-menu-shell {
    pointer-events: none;
  }

  .mobile-menu-shell.is-open {
    pointer-events: auto;
  }

  .mobile-menu-backdrop {
    opacity: 0;
    transition: opacity 260ms ease;
  }

  .mobile-menu-panel {
    transform: translateX(-104%);
    transition: transform 360ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .mobile-menu-shell.is-open .mobile-menu-backdrop {
    opacity: 1;
  }

  .mobile-menu-shell.is-open .mobile-menu-panel {
    transform: translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu-backdrop,
    .mobile-menu-panel {
      transition: none;
    }
  }
</style>

<script>
  const desktopStickyNav = document.getElementById('desktop-sticky-nav');
  const desktopNavSpacer = document.getElementById('desktop-nav-spacer');
  const desktopLogoShield = document.getElementById('logo-shield');
  const desktopNavQuery = window.matchMedia('(min-width: 768px)');
  let desktopStickyOffset = 0;


  const updateDesktopScrollLogoLeft = () => {
    if (!desktopStickyNav || !desktopLogoShield || !desktopNavQuery.matches) return;
    const logoLeft = desktopLogoShield.getBoundingClientRect().left;
    desktopStickyNav.style.setProperty('--desktop-scroll-logo-left', `${logoLeft}px`);
  };
  const updateDesktopStickyNav = () => {
    if (!desktopStickyNav || !desktopNavSpacer) return;

    if (!desktopNavQuery.matches) {
      desktopStickyNav.classList.remove('is-fixed');
      desktopNavSpacer.classList.remove('is-active');
      return;
    }

    updateDesktopScrollLogoLeft();
    const shouldFix = window.scrollY >= desktopStickyOffset;
    desktopStickyNav.classList.toggle('is-fixed', shouldFix);
    desktopNavSpacer.classList.toggle('is-active', shouldFix);
  };

  const measureDesktopStickyNav = () => {
    if (!desktopStickyNav || !desktopNavSpacer) return;
    desktopStickyNav.classList.remove('is-fixed');
    desktopNavSpacer.classList.remove('is-active');
    updateDesktopScrollLogoLeft();
    desktopStickyOffset = desktopStickyNav.getBoundingClientRect().top + window.scrollY;
    updateDesktopStickyNav();
  };

  window.addEventListener('scroll', updateDesktopStickyNav, { passive: true });
  window.addEventListener('resize', measureDesktopStickyNav);
  window.addEventListener('load', measureDesktopStickyNav);
  desktopNavQuery.addEventListener('change', measureDesktopStickyNav);
  window.requestAnimationFrame(measureDesktopStickyNav);
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  const closeBtn = document.getElementById('mobile-menu-close');
  const backdrop = document.getElementById('mobile-menu-backdrop');
  const panel = menu?.querySelector('.mobile-menu-panel');
  let closeTimer;

  const setMobileMenuIcons = (isOpen) => {
    if (!btn || !menuIcon || !closeIcon) return;
    btn.setAttribute('aria-expanded', String(isOpen));
    menuIcon.classList.toggle('hidden', isOpen);
    closeIcon.classList.toggle('hidden', !isOpen);
  };

  const openMobileMenu = () => {
    if (!menu) return;
    window.clearTimeout(closeTimer);
    menu.classList.remove('hidden');
    menu.setAttribute('aria-hidden', 'false');
    setMobileMenuIcons(true);
    document.body.classList.add('overflow-hidden');
    window.requestAnimationFrame(() => {
      menu.classList.add('is-open');
    });
  };

  const closeMobileMenu = () => {
    if (!menu || menu.classList.contains('hidden')) return;
    window.clearTimeout(closeTimer);
    menu.classList.remove('is-open');
    menu.setAttribute('aria-hidden', 'true');
    setMobileMenuIcons(false);
    document.body.classList.remove('overflow-hidden');

    const finishClose = () => {
      if (btn?.getAttribute('aria-expanded') === 'false') {
        menu.classList.add('hidden');
      }
    };

    closeTimer = window.setTimeout(finishClose, 420);
    panel?.addEventListener('transitionend', function handleTransition(event) {
      if (event.propertyName !== 'transform') return;
      panel.removeEventListener('transitionend', handleTransition);
      window.clearTimeout(closeTimer);
      finishClose();
    });
  };

  btn?.addEventListener('click', () => {
    const isExpanded = btn.getAttribute('aria-expanded') === 'true';
    if (isExpanded) {
      closeMobileMenu();
    } else {
      openMobileMenu();
    }
  });

  closeBtn?.addEventListener('click', closeMobileMenu);
  backdrop?.addEventListener('click', closeMobileMenu);
  menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMobileMenu));
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeMobileMenu();
  });
</script>

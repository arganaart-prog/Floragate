---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { WHATSAPP_NUMBER, WHATSAPP_LABEL, INSTAGRAM_URL, INSTAGRAM_HANDLE } from '../data/constants';

// SEO Meta
const title = "Kontak & Hubungi Floragate - Toko Bunga Malang";
const description = "Hubungi Floragate untuk konsultasi dan pemesanan karangan bunga di Malang. WhatsApp Business aktif setiap hari 07.00-21.00 WIB. Layanan cepat & terpercaya.";
---

<Layout title={title} description={description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Breadcrumb -->
    <Breadcrumb items={[{ label: 'Kontak' }]} />

    <!-- Page Header -->
    <div class="text-center max-w-2xl mx-auto mt-6 mb-16">
      <h1 class="font-serif text-3xl sm:text-4xl font-bold text-slate-800">Hubungi Floragate</h1>
      <p class="text-slate-500 text-sm mt-3 leading-relaxed">
        Punya pertanyaan atau ingin segera memesan karangan bunga? Hubungi tim kami melalui WhatsApp atau kunjungi media sosial kami.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      
      <!-- Left: Contact Form → WhatsApp -->
      <div class="bg-white p-6 sm:p-8 rounded-xl border border-soft-cream/60 shadow-xs">
        <h2 class="font-serif text-xl font-bold text-slate-800 mb-2">Kirim Pesan Langsung</h2>
        <p class="text-xs text-slate-500 mb-6">Isi formulir di bawah, lalu klik tombol kirim. Anda akan langsung diarahkan ke WhatsApp kami dengan pesan yang sudah terisi otomatis.</p>
        
        <form id="contact-form" class="space-y-5" data-phone={WHATSAPP_NUMBER}>
          <div>
            <label for="contact-name" class="block text-sm font-semibold text-slate-700 mb-1.5">Nama Lengkap</label>
            <input 
              type="text" 
              id="contact-name" 
              name="name"
              maxlength="80"
              autocomplete="name"
              placeholder="Contoh: Budi Santoso"
              required
              class="w-full px-4 py-2.5 bg-clean-ivory/40 border border-soft-cream/80 rounded-md text-sm text-slate-800 placeholder:text-slate-400 focus:outline-hidden focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
            />
          </div>

          <div>
            <label for="contact-subject" class="block text-sm font-semibold text-slate-700 mb-1.5">Keperluan</label>
            <select 
              id="contact-subject" 
              name="subject"
              required
              class="w-full px-4 py-2.5 bg-clean-ivory/40 border border-soft-cream/80 rounded-md text-sm text-slate-800 focus:outline-hidden focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
            >
              <option value="" disabled selected>Pilih keperluan Anda</option>
              <option value="Pesan Bunga Papan">Pesan Bunga Papan</option>
              <option value="Pesan Standing Flower">Pesan Standing Flower</option>
              <option value="Pesan Hand Bouquet">Pesan Hand Bouquet</option>
              <option value="Pesan Paper Flower">Pesan Paper Flower</option>
              <option value="Pesan Bunga Meja">Pesan Bunga Meja</option>
              <option value="Konsultasi Harga">Konsultasi Harga</option>
              <option value="Tanya Jangkauan Pengiriman">Tanya Jangkauan Pengiriman</option>
              <option value="Lainnya">Lainnya</option>
            </select>
          </div>

          <div>
            <label for="contact-message" class="block text-sm font-semibold text-slate-700 mb-1.5">Pesan Anda</label>
            <textarea 
              id="contact-message" 
              name="message"
              maxlength="800"
              rows="4"
              placeholder="Tuliskan detail pertanyaan atau kebutuhan Anda..."
              required
              class="w-full px-4 py-2.5 bg-clean-ivory/40 border border-soft-cream/80 rounded-md text-sm text-slate-800 placeholder:text-slate-400 focus:outline-hidden focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-none"
            ></textarea>
          </div>

          <button 
            type="submit" 
            id="contact-submit-btn"
            class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 border border-transparent text-sm font-semibold rounded-md shadow-xs text-white bg-emerald-600 hover:bg-emerald-700 focus:outline-hidden transition-colors duration-300 cursor-pointer"
          >
            <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.965C16.588 2.02 14.12 1.022 11.5 1.022c-5.438 0-9.863 4.372-9.867 9.802-.001 1.73.473 3.42 1.37 4.947l-.994 3.63 3.734-.967c1.554.84 3.123 1.282 4.304 1.282zm11.304-6.858c-.31-.155-1.838-.895-2.122-.997-.284-.102-.49-.153-.696.155-.205.308-.796.997-.975 1.199-.179.203-.359.227-.669.073-.31-.155-1.31-.476-2.494-1.516-.922-.811-1.545-1.812-1.725-2.12-.179-.31-.018-.478.137-.631.14-.139.31-.359.464-.539.155-.179.206-.308.31-.513.102-.206.051-.385-.026-.539-.077-.154-.696-1.649-.953-2.263-.25-.596-.503-.515-.69-.525l-.59-.01c-.206 0-.54.077-.822.385-.282.308-1.079 1.052-1.079 2.565 0 1.513 1.103 2.977 1.257 3.182.155.206 2.17 3.267 5.257 4.569.735.31 1.307.495 1.753.634.739.231 1.412.197 1.944.119.593-.087 1.838-.739 2.095-1.453.258-.713.258-1.325.18-1.453-.077-.128-.283-.205-.593-.36z" />
            </svg>
            Kirim via WhatsApp
          </button>
        </form>
      </div>

      <!-- Right: Contact Info Cards -->
      <div class="space-y-6">        <!-- WhatsApp Card -->
        <div class="bg-white p-6 rounded-xl border border-soft-cream/60 shadow-xs flex items-start gap-5">
          <div class="p-3 bg-emerald-50 text-emerald-600 rounded-lg flex-shrink-0">
            <svg class="h-7 w-7 fill-current" viewBox="0 0 24 24">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.965C16.588 2.02 14.12 1.022 11.5 1.022c-5.438 0-9.863 4.372-9.867 9.802-.001 1.73.473 3.42 1.37 4.947l-.994 3.63 3.734-.967c1.554.84 3.123 1.282 4.304 1.282zm11.304-6.858c-.31-.155-1.838-.895-2.122-.997-.284-.102-.49-.153-.696.155-.205.308-.796.997-.975 1.199-.179.203-.359.227-.669.073-.31-.155-1.31-.476-2.494-1.516-.922-.811-1.545-1.812-1.725-2.12-.179-.31-.018-.478.137-.631.14-.139.31-.359.464-.539.155-.179.206-.308.31-.513.102-.206.051-.385-.026-.539-.077-.154-.696-1.649-.953-2.263-.25-.596-.503-.515-.69-.525l-.59-.01c-.206 0-.54.077-.822.385-.282.308-1.079 1.052-1.079 2.565 0 1.513 1.103 2.977 1.257 3.182.155.206 2.17 3.267 5.257 4.569.735.31 1.307.495 1.753.634.739.231 1.412.197 1.944.119.593-.087 1.838-.739 2.095-1.453.258-.713.258-1.325.18-1.453-.077-.128-.283-.205-.593-.36z" />
            </svg>
          </div>
          <div>
            <h3 class="font-serif font-bold text-slate-800">WhatsApp Business</h3>
            <a href={`https://wa.me/${WHATSAPP_NUMBER}`} target="_blank" rel="noopener noreferrer" class="text-sm text-primary font-semibold hover:text-secondary transition-colors">
              {WHATSAPP_LABEL}
            </a>
            <p class="text-xs text-slate-500 mt-1">Respon cepat dan personal dari admin Floragate.</p>
          </div>
        </div>

        <!-- Instagram Card -->
        <div class="bg-white p-6 rounded-xl border border-soft-cream/60 shadow-xs flex items-start gap-5">
          <div class="p-3 bg-pink-50 text-pink-500 rounded-lg flex-shrink-0">
            <svg class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204 .013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </div>
          <div>
            <h3 class="font-serif font-bold text-slate-800">Instagram</h3>
            <a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer" class="text-sm text-primary font-semibold hover:text-secondary transition-colors">
              {INSTAGRAM_HANDLE}
            </a>
            <p class="text-xs text-slate-500 mt-1">Lihat galeri portofolio karangan bunga terbaru kami.</p>
          </div>
        </div>

        <!-- Service Area Card -->
        <div class="bg-white p-6 rounded-xl border border-soft-cream/60 shadow-xs flex items-start gap-5">
          <div class="p-3 bg-primary/10 text-primary rounded-lg flex-shrink-0">
            <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-serif font-bold text-slate-800">Area Layanan</h3>
            <p class="text-sm text-slate-600 font-medium">Kota Malang, Kabupaten Malang, Kota Batu</p>
            <p class="text-xs text-slate-500 mt-1">Termasuk Singosari, Lawang, Kepanjen, Bululawang, dan sekitarnya.</p>
          </div>
        </div>

        <!-- Operating Hours Card -->
        <div class="bg-white p-6 rounded-xl border border-soft-cream/60 shadow-xs flex items-start gap-5">
          <div class="p-3 bg-soft-cream/30 text-secondary-dark rounded-lg flex-shrink-0">
            <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-serif font-bold text-slate-800">Jam Operasional</h3>
            <p class="text-sm text-slate-600 font-medium">Setiap Hari (Senin - Minggu)</p>
            <p class="text-xs text-slate-500 mt-1">Pukul 07.00 - 21.00 WIB</p>
          </div>
        </div>

      </div>
    </div>

  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const nameEl = document.getElementById('contact-name') as HTMLInputElement;
      const subjectEl = document.getElementById('contact-subject') as HTMLSelectElement;
      const messageEl = document.getElementById('contact-message') as HTMLTextAreaElement;
      
      const name = (nameEl?.value.trim() || '').slice(0, 80);
      const subject = subjectEl?.value || '';
      const message = (messageEl?.value.trim() || '').slice(0, 800);

      if (!name || !subject || !message) return;
      
      const phone = (form.getAttribute('data-phone') || '6281234567890').replace(/\D/g, '') || '6281234567890';
      const waText = `Halo Floragate, saya ${name}.\n\nKeperluan: ${subject}\n\nPesan:\n${message}\n\nMohon direspon, terima kasih.`;
      const encodedText = encodeURIComponent(waText);
      const waUrl = `https://wa.me/${phone}?text=${encodedText}`;
      
      window.open(waUrl, '_blank', 'noopener,noreferrer');
    });
  }
</script>

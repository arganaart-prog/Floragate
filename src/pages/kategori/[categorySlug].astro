---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { CATEGORIES, PRODUCTS } from '../../data/products';
import { WHATSAPP_NUMBER } from '../../data/constants';

export async function getStaticPaths() {
  return CATEGORIES.map(category => {
    const filteredProducts = PRODUCTS.filter(p => p.categorySlug === category.slug);
    return {
      params: { categorySlug: category.slug },
      props: { category, products: filteredProducts }
    };
  });
}

const { category, products } = Astro.props;
---

<Layout title={category.seoTitle} description={category.seoDescription}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Breadcrumb -->
    <Breadcrumb 
      items={[
        { label: 'Katalog', href: '/katalog/' },
        { label: category.name }
      ]} 
    />

    <!-- Category Header -->
    <div class="mt-6 mb-12 max-w-3xl">
      <span class="text-xs font-semibold text-secondary uppercase tracking-widest block mb-2">Kategori Pilihan</span>
      <h1 class="font-serif text-3xl sm:text-4xl font-bold text-slate-800">
        Jual {category.name} Malang
      </h1>
      <p class="text-slate-500 text-sm mt-3 leading-relaxed">
        {category.description} Floragate menawarkan pilihan toko bunga Malang murah dan berkualitas dengan desain elegan, bunga segar, harga bersahabat, serta pengiriman cepat di wilayah Malang Kota, Kabupaten Malang, dan Kota Batu.
      </p>
    </div>

    <!-- Products Grid -->
    {products.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map(product => (
          <ProductCard product={product} />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 bg-white rounded-lg border border-soft-cream/60 space-y-4">
        <svg class="h-16 w-16 text-slate-300 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <h3 class="font-serif font-bold text-lg text-slate-700">Belum Ada Produk</h3>
        <p class="text-sm text-slate-500 max-w-sm mx-auto">Produk untuk kategori ini sedang dalam tahap pembaharuan desain. Hubungi admin untuk katalog kustom.</p>
        <a 
          href={`https://wa.me/${WHATSAPP_NUMBER}?text=Halo%20Floragate,%20saya%20ingin%20tanya%20mengenai%20katalog%20bunga%20papan%20atau%20standing%20flower%20lainnya.`} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="inline-flex justify-center px-5 py-2.5 bg-primary text-white font-semibold text-xs rounded-md"
        >
          Hubungi Admin WA
        </a>
      </div>
    )}

  </div>
</Layout>

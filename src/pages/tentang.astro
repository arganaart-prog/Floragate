---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { withBase } from '../utils/paths';

// SEO Meta
const title = "Tentang Floragate - Layanan Pemesanan Bunga Malang Terpercaya";
const description = "Floragate adalah layanan pemesanan karangan bunga di Malang yang bekerja sama dengan mitra florist lokal berpengalaman. Kami hadir untuk memudahkan Anda mengirim bunga papan, standing flower, dan buket bunga di Malang.";
---

<Layout title={title} description={description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Breadcrumb -->
    <Breadcrumb items={[{ label: 'Tentang Kami' }]} />

    <!-- Hero About -->
    <section class="mt-6 mb-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <span class="text-xs font-semibold text-secondary uppercase tracking-widest">Tentang Floragate</span>
          <h1 class="font-serif text-3xl sm:text-4xl font-bold text-slate-800 leading-snug">
            Menghadirkan Keindahan Bunga Segar untuk Setiap Momen di Malang
          </h1>
          <p class="text-slate-600 text-sm leading-relaxed">
            <strong>Floragate</strong> adalah layanan pemesanan karangan bunga online yang hadir di Kota Malang dan sekitarnya. Kami membangun jembatan antara pelanggan yang membutuhkan rangkaian bunga berkualitas dengan para <strong>mitra florist lokal berpengalaman</strong> yang telah bertahun-tahun berkarya di industri bunga segar Malang Raya.
          </p>
          <p class="text-slate-600 text-sm leading-relaxed">
            Misi kami sederhana: membuat proses pemesanan karangan bunga menjadi <strong>mudah, cepat, transparan, dan terpercaya</strong>. Anda cukup memilih desain dari katalog kami, menghubungi admin via WhatsApp, dan karangan bunga akan segera dirangkai oleh tangan-tangan terampil mitra florist profesional kami.
          </p>
          <div class="flex flex-wrap gap-3 pt-2">
            <span class="inline-flex items-center px-3 py-1.5 bg-primary/5 border border-primary/10 rounded-md text-xs font-semibold text-primary">
              ✅ Mitra Florist Lokal
            </span>
            <span class="inline-flex items-center px-3 py-1.5 bg-primary/5 border border-primary/10 rounded-md text-xs font-semibold text-primary">
              ✅ Bunga Segar Pilihan
            </span>
            <span class="inline-flex items-center px-3 py-1.5 bg-primary/5 border border-primary/10 rounded-md text-xs font-semibold text-primary">
              ✅ Proses Cepat 3 Jam
            </span>
          </div>
        </div>

        <!-- Visual -->
        <div class="relative flex justify-center">
          <div class="w-full max-w-sm aspect-square rounded-xl border border-soft-cream/60 overflow-hidden shadow-lg">
            <img 
              src={withBase('/images/produk/standing-lilac.webp')} 
              alt="Rangkaian standing flower elegan dari mitra florist Floragate Malang" 
              width="600" 
              height="600" 
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Accent decoration -->
          <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-secondary/10 border border-secondary/20 rounded-xl -z-10"></div>
          <div class="absolute -top-4 -left-4 w-16 h-16 bg-primary/5 border border-primary/10 rounded-xl -z-10"></div>
        </div>
      </div>
    </section>

    <!-- Values Section -->
    <section class="py-16 border-t border-soft-cream/60">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="font-serif text-3xl font-bold text-slate-800">Mengapa Floragate?</h2>
        <p class="text-slate-500 text-sm mt-3 leading-relaxed">Nilai-nilai yang kami pegang erat dalam setiap rangkaian bunga yang kami sampaikan.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        <!-- Value 1 -->
        <div class="bg-white p-8 rounded-lg border border-soft-cream/60 shadow-xs hover-gold-grow text-center">
          <div class="w-14 h-14 bg-primary/5 rounded-full flex items-center justify-center mx-auto text-primary mb-5">
            <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
          </div>
          <h3 class="font-serif font-bold text-lg text-slate-800">Kolaborasi dengan Florist Lokal</h3>
          <p class="text-slate-500 text-sm mt-3 leading-relaxed">
            Kami bermitra dengan para perangkai bunga profesional di Malang yang telah berpengalaman bertahun-tahun. Setiap karangan bunga dikerjakan langsung oleh tangan ahlinya.
          </p>
        </div>

        <!-- Value 2 -->
        <div class="bg-white p-8 rounded-lg border border-soft-cream/60 shadow-xs hover-gold-grow text-center">
          <div class="w-14 h-14 bg-primary/5 rounded-full flex items-center justify-center mx-auto text-primary mb-5">
            <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="font-serif font-bold text-lg text-slate-800">Amanah & Terpercaya</h3>
          <p class="text-slate-500 text-sm mt-3 leading-relaxed">
            Setiap pesanan ditangani secara personal. Kami menyediakan update foto progress dan foto bukti pengiriman ke lokasi tujuan agar pelanggan merasa tenang dan puas.
          </p>
        </div>

        <!-- Value 3 -->
        <div class="bg-white p-8 rounded-lg border border-soft-cream/60 shadow-xs hover-gold-grow text-center">
          <div class="w-14 h-14 bg-primary/5 rounded-full flex items-center justify-center mx-auto text-primary mb-5">
            <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
            </svg>
          </div>
          <h3 class="font-serif font-bold text-lg text-slate-800">Respon Cepat & Efisien</h3>
          <p class="text-slate-500 text-sm mt-3 leading-relaxed">
            Admin kami siap melayani konsultasi dan pemesanan melalui WhatsApp setiap hari, dari pukul 07.00 hingga 21.00 WIB. Proses pengerjaan estimasi hanya 3-4 jam.
          </p>
        </div>
      </div>
    </section>

    <!-- Model Kerja Section -->
    <section class="py-16 border-t border-soft-cream/60">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <div class="bg-white p-8 rounded-xl border border-soft-cream/60 space-y-5">
            <h3 class="font-serif text-lg font-bold text-slate-800">Bagaimana Model Kerja Floragate?</h3>
            <div class="space-y-4 text-sm text-slate-600 leading-relaxed">
              <div class="flex items-start gap-3">
                <span class="mt-0.5 w-6 h-6 flex items-center justify-center bg-primary text-white text-xs font-bold rounded-full flex-shrink-0">1</span>
                <p>Anda memilih desain bunga dari katalog online dan menghubungi admin Floragate via WhatsApp.</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="mt-0.5 w-6 h-6 flex items-center justify-center bg-primary text-white text-xs font-bold rounded-full flex-shrink-0">2</span>
                <p>Admin mengkonfirmasi pesanan, detail ucapan, alamat, dan harga final kepada Anda.</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="mt-0.5 w-6 h-6 flex items-center justify-center bg-primary text-white text-xs font-bold rounded-full flex-shrink-0">3</span>
                <p>Pesanan diteruskan ke <strong>mitra florist lokal terverifikasi</strong> kami di Malang untuk segera dirangkai menggunakan bunga segar berkualitas terbaik.</p>
              </div>
              <div class="flex items-start gap-3">
                <span class="mt-0.5 w-6 h-6 flex items-center justify-center bg-primary text-white text-xs font-bold rounded-full flex-shrink-0">4</span>
                <p>Bunga selesai dirangkai, difoto untuk Anda, dan langsung dikirim oleh kurir ke alamat tujuan di wilayah Malang Raya dan Kota Batu.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="order-1 lg:order-2 space-y-6">
          <h2 class="font-serif text-3xl font-bold text-slate-800 leading-snug">
            Kami Bukan Florist Biasa — Kami <span class="text-secondary">Mitra</span> Anda
          </h2>
          <p class="text-slate-600 text-sm leading-relaxed">
            Floragate tidak hanya menjual bunga. Kami hadir sebagai <strong>jembatan digital</strong> yang menghubungkan Anda dengan jaringan florist profesional lokal di Kota Malang. Setiap karangan bunga yang Anda pesan dikerjakan oleh tangan-tangan ahli yang memahami seni merangkai bunga dengan perhatian penuh pada kualitas dan keindahan.
          </p>
          <p class="text-slate-600 text-sm leading-relaxed">
            Dengan model kerja kolaboratif ini, kami dapat memastikan <strong>kecepatan pengerjaan, kualitas material, serta harga yang kompetitif</strong> untuk setiap pesanan karangan bunga Anda di Malang.
          </p>
          <WhatsAppButton 
            whatsappText="Halo Floragate, saya ingin mengetahui lebih lanjut tentang layanan pemesanan bunga kalian di Malang." 
            text="Tanya Lebih Lanjut via WhatsApp"
          />
        </div>
      </div>
    </section>

  </div>
</Layout>


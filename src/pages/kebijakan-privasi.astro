---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { WHATSAPP_LABEL, INSTAGRAM_HANDLE } from '../data/constants';

const title = 'Kebijakan Privasi Floragate';
const description = 'Kebijakan Privasi Floragate menjelaskan data yang dikumpulkan, tujuan penggunaan, pembagian data, keamanan, dan cara menghubungi admin terkait data pemesanan bunga.';
const lastUpdated = '1 Juli 2026';

const sections = [
  {
    title: 'Data yang Kami Kumpulkan',
    body: [
      'Saat Anda bertanya atau memesan melalui Floragate, kami dapat menerima nama pemesan, nomor WhatsApp, alamat pengiriman, nama penerima, detail ucapan, pilihan produk, jadwal pengiriman, dan informasi pembayaran yang Anda kirimkan secara sukarela.',
      'Website Floragate juga dapat memproses data teknis dasar seperti halaman yang dibuka, perangkat, browser, dan waktu akses untuk membantu menjaga performa serta keamanan website.',
    ],
  },
  {
    title: 'Tujuan Penggunaan Data',
    body: [
      'Data digunakan untuk memproses pesanan, menghubungi Anda tentang detail rangkaian bunga, mengatur pengiriman, mengirim foto hasil, memberi bukti pengiriman, menangani komplain, dan meningkatkan kualitas layanan Floragate.',
      'Kami tidak menggunakan data pelanggan untuk menjual daftar kontak atau mengirim promosi berulang tanpa konteks pemesanan atau persetujuan yang wajar dari pelanggan.',
    ],
  },
  {
    title: 'Pembagian Data kepada Pihak Terkait',
    body: [
      'Sebagian data pesanan dapat dibagikan kepada mitra florist, kurir lokal, atau pihak pembayaran hanya sejauh diperlukan untuk menyelesaikan pesanan Anda.',
      'Contohnya adalah alamat tujuan untuk kurir, detail tulisan untuk florist, atau bukti transaksi untuk administrasi pembayaran.',
    ],
  },
  {
    title: 'Penyimpanan dan Keamanan',
    body: [
      'Kami menyimpan data percakapan dan data pesanan selama diperlukan untuk administrasi, riwayat layanan, penyelesaian keluhan, dan kebutuhan pencatatan internal.',
      'Kami berupaya menjaga data tetap aman dengan membatasi akses hanya kepada pihak yang membutuhkan untuk memproses pesanan.',
    ],
  },
  {
    title: 'Hak Pelanggan',
    body: [
      'Anda dapat menghubungi admin untuk meminta koreksi data pesanan, klarifikasi penggunaan data, atau penghapusan data tertentu sepanjang tidak bertentangan dengan kebutuhan administrasi transaksi yang sah.',
      'Untuk permintaan terkait privasi, hubungi WhatsApp Floragate dan sertakan konteks pesanan agar kami dapat memverifikasi permintaan dengan tepat.',
    ],
  },
  {
    title: 'Perubahan Kebijakan',
    body: [
      'Kebijakan Privasi dapat diperbarui dari waktu ke waktu mengikuti kebutuhan operasional Floragate. Tanggal pembaruan terbaru akan ditampilkan pada halaman ini.',
    ],
  },
];
---

<Layout title={title} description={description}>
  <section class="bg-clean-ivory/80 border-b border-soft-cream/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10">
      <Breadcrumb items={[{ label: 'Kebijakan Privasi' }]} />

      <div class="mt-8 max-w-4xl">
        <span class="inline-flex rounded-full border border-secondary/35 bg-white/75 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.18em] text-secondary-dark shadow-xs">
          Privasi Pelanggan
        </span>
        <h1 class="mt-5 font-serif text-3xl sm:text-5xl font-bold leading-tight text-slate-800">Kebijakan Privasi Floragate</h1>
        <p class="mt-4 max-w-3xl text-sm sm:text-base leading-relaxed text-slate-600">
          Kami menghargai kepercayaan pelanggan. Halaman ini menjelaskan bagaimana Floragate mengelola informasi yang Anda kirimkan saat bertanya, berkonsultasi, atau memesan karangan bunga.
        </p>
        <p class="mt-5 inline-flex rounded-md bg-primary/10 px-4 py-2 text-xs font-semibold text-primary">Terakhir diperbarui: {lastUpdated}</p>
      </div>
    </div>
  </section>

  <section class="bg-white py-14 sm:py-18">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-8 lg:gap-12">
        <aside class="lg:sticky lg:top-24 h-fit rounded-lg border border-soft-cream/70 bg-primary text-white p-6 shadow-[0_22px_54px_rgba(63,75,55,0.14)]">
          <p class="font-serif text-2xl font-bold">Ringkasan</p>
          <p class="mt-3 text-sm leading-relaxed text-white/78">
            Data pelanggan dipakai untuk menjalankan pesanan, komunikasi admin, pengiriman, dan dokumentasi layanan.
          </p>
          <div class="mt-6 space-y-3 border-t border-white/15 pt-5 text-sm text-white/82">
            <p>WhatsApp: {WHATSAPP_LABEL}</p>
            <p>Instagram: {INSTAGRAM_HANDLE}</p>
            <p>Jam admin: 09.00 - 23.00 WIB</p>
          </div>
          <div class="mt-6">
            <WhatsAppButton whatsappText="Halo Floragate, saya ingin bertanya tentang Kebijakan Privasi." text="Hubungi Admin" className="w-full justify-center bg-secondary text-primary-dark hover:bg-secondary-light" />
          </div>
        </aside>

        <div class="space-y-5">
          {sections.map((section, index) => (
            <article class="rounded-lg border border-soft-cream/70 bg-white p-6 sm:p-7 shadow-[0_14px_38px_rgba(15,23,42,0.04)]">
              <div class="flex items-start gap-4">
                <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-clean-ivory text-sm font-bold text-primary ring-1 ring-soft-cream">
                  {index + 1}
                </span>
                <div>
                  <h2 class="font-serif text-xl sm:text-2xl font-bold text-slate-800">{section.title}</h2>
                  <div class="mt-3 space-y-3">
                    {section.body.map((paragraph) => (
                      <p class="text-sm leading-relaxed text-slate-600">{paragraph}</p>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
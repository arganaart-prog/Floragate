---
import Layout from '../layouts/Layout.astro';
import { WHATSAPP_NUMBER } from '../data/constants';
import { withBase } from '../utils/paths';

Astro.response.status = 404;

const title = 'Halaman Tidak Ditemukan';
const description = 'Halaman yang Anda cari tidak tersedia di Floragate. Kembali ke katalog toko bunga Malang murah dan berkualitas atau hubungi admin Floragate.';
const whatsappText = 'Halo Floragate, saya membuka halaman yang tidak ditemukan. Bisa bantu arahkan saya ke katalog atau rekomendasi bunga?';
const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(whatsappText)}`;

const quickLinks = [
  {
    label: 'Katalog Bunga',
    href: '/katalog/',
    text: 'Lihat pilihan bunga papan, bouquet, standing flower, dan bunga meja.'
  },
  {
    label: 'Cara Pemesanan',
    href: '/cara-pesan/',
    text: 'Ikuti alur pemesanan bunga yang cepat dan mudah via WhatsApp.'
  },
  {
    label: 'Kontak Floragate',
    href: '/kontak/',
    text: 'Hubungi admin untuk rekomendasi produk atau cek pengiriman.'
  }
];
---

<Layout title={title} description={description} robots="noindex, follow" showTestimonials={false}>
  <section class="relative overflow-hidden bg-clean-ivory">
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-secondary/60 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-soft-cream to-transparent"></div>

    <div class="mx-auto grid min-h-[calc(100vh-9rem)] max-w-7xl items-center gap-10 px-4 py-16 sm:px-6 sm:py-20 lg:grid-cols-[1.03fr_0.97fr] lg:px-8 lg:py-24">
      <div class="max-w-2xl">
        <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-secondary/30 bg-white/80 px-4 py-2 text-xs font-semibold text-primary shadow-xs">
          <span class="h-2 w-2 rounded-full bg-secondary"></span>
          Jalur halaman tidak ditemukan
        </div>

        <p class="font-serif text-[5.5rem] font-bold leading-none text-primary sm:text-[7rem] lg:text-[8rem]">404</p>
        <h1 class="mt-4 font-serif text-3xl font-bold leading-tight text-slate-900 sm:text-5xl">
          Halaman ini belum mekar di Floragate.
        </h1>
        <p class="mt-5 max-w-xl text-sm leading-7 text-slate-600 sm:text-base">
          Link yang Anda buka mungkin sudah berubah, salah ketik, atau produknya sedang kami rapikan. Anda tetap bisa lanjut mencari karangan bunga Malang yang murah, berkualitas, dan siap dipesan cepat.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href={withBase('/katalog/')}
            class="inline-flex items-center justify-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white shadow-md transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary-dark hover:shadow-lg focus:outline-hidden"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h10" />
            </svg>
            Lihat Katalog
          </a>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-secondary px-6 py-3 text-sm font-semibold text-white shadow-md transition-all duration-300 hover:-translate-y-0.5 hover:bg-secondary-dark hover:shadow-lg focus:outline-hidden"
          >
            <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.37 9.864-9.799.002-2.63-1.023-5.101-2.885-6.965C16.588 2.02 14.12 1.022 11.5 1.022c-5.438 0-9.863 4.372-9.867 9.802-.001 1.73.473 3.42 1.37 4.947l-.994 3.63 3.734-.967c1.554.84 3.123 1.282 4.304 1.282zm11.304-6.858c-.31-.155-1.838-.895-2.122-.997-.284-.102-.49-.153-.696.155-.205.308-.796.997-.975 1.199-.179.203-.359.227-.669.073-.31-.155-1.31-.476-2.494-1.516-.922-.811-1.545-1.812-1.725-2.12-.179-.31-.018-.478.137-.631.14-.139.31-.359.464-.539.155-.179.206-.308.31-.513.102-.206.051-.385-.026-.539-.077-.154-.696-1.649-.953-2.263-.25-.596-.503-.515-.69-.525l-.59-.01c-.206 0-.54.077-.822.385-.282.308-1.079 1.052-1.079 2.565 0 1.513 1.103 2.977 1.257 3.182.155.206 2.17 3.267 5.257 4.569.735.31 1.307.495 1.753.634.739.231 1.412.197 1.944.119.593-.087 1.838-.739 2.095-1.453.258-.713.258-1.325.18-1.453-.077-.128-.283-.205-.593-.36z" />
            </svg>
            Tanya Admin
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="rounded-lg border border-soft-cream/80 bg-white/95 p-5 shadow-[0_24px_70px_rgba(63,75,55,0.13)] sm:p-7">
          <div class="flex items-center justify-between gap-4 border-b border-soft-cream/70 pb-5">
            <div class="flex items-center gap-4">
              <div class="flex h-14 w-14 items-center justify-center rounded-md bg-clean-ivory ring-1 ring-soft-cream/80">
                <img src={withBase('/images/logo/logo%20Floragate%201.png')} alt="Floragate" class="h-11 w-auto object-contain" loading="eager" />
              </div>
              <div>
                <p class="text-xs font-semibold uppercase text-secondary">Floragate Assist</p>
                <p class="mt-1 text-sm font-bold text-slate-800">Rute cepat untuk lanjut pesan</p>
              </div>
            </div>
            <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary">404</span>
          </div>

          <div class="py-5">
            <div class="rounded-md bg-clean-ivory/70 px-4 py-4 text-sm text-slate-600 ring-1 ring-soft-cream/70">
              <p class="font-semibold text-slate-800">Halaman tujuan tidak tersedia.</p>
              <p class="mt-1 text-xs leading-6">Pilih salah satu jalur berikut untuk kembali ke layanan Floragate.</p>
            </div>
          </div>

          <div class="divide-y divide-soft-cream/70 border-y border-soft-cream/70">
            {quickLinks.map((item) => (
              <a href={withBase(item.href)} class="group flex items-start justify-between gap-4 py-4 transition-colors hover:text-primary">
                <span>
                  <span class="block text-sm font-bold text-slate-800 transition-colors group-hover:text-primary">{item.label}</span>
                  <span class="mt-1 block text-xs leading-5 text-slate-500">{item.text}</span>
                </span>
                <svg class="mt-1 h-4 w-4 flex-none text-secondary transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6 6 6-6 6" />
                </svg>
              </a>
            ))}
          </div>

          <div class="mt-5 grid grid-cols-3 gap-3 text-center">
            <div class="rounded-md bg-primary/5 px-3 py-3">
              <p class="font-serif text-lg font-bold text-primary">3 Jam</p>
              <p class="mt-1 text-[11px] text-slate-500">Pengerjaan</p>
            </div>
            <div class="rounded-md bg-secondary/10 px-3 py-3">
              <p class="font-serif text-lg font-bold text-primary">Gratis</p>
              <p class="mt-1 text-[11px] text-slate-500">Ongkir kota</p>
            </div>
            <div class="rounded-md bg-primary/5 px-3 py-3">
              <p class="font-serif text-lg font-bold text-primary">Segar</p>
              <p class="mt-1 text-[11px] text-slate-500">Bunganya</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { WHATSAPP_LABEL } from '../data/constants';
import { withBase } from '../utils/paths';

const title = 'Syarat dan Ketentuan Floragate';
const description = 'Syarat dan Ketentuan Floragate berisi aturan pemesanan, pembayaran, pengiriman, revisi, pembatalan, komplain, dan tanggung jawab pelanggan.';
const lastUpdated = '1 Juli 2026';

const terms = [
  {
    title: 'Ruang Lingkup Layanan',
    body: 'Floragate menyediakan layanan pemesanan karangan bunga, bunga papan, standing flower, hand bouquet, paper flower, dan bunga meja untuk wilayah Malang Raya dan sekitarnya. Setiap pesanan diproses berdasarkan detail yang dikirimkan pelanggan melalui WhatsApp resmi Floragate.',
  },
  {
    title: 'Konfirmasi Pesanan',
    body: 'Pesanan dianggap masuk setelah pelanggan mengirimkan detail produk, ucapan, nama pengirim, nama penerima, alamat tujuan, tanggal, jam pengiriman, dan admin mengonfirmasi ketersediaan slot pengerjaan.',
  },
  {
    title: 'Harga dan Pembayaran',
    body: 'Harga pada website adalah harga mulai dan dapat berubah sesuai ukuran, tingkat kerumitan desain, pilihan bunga, lokasi pengiriman, serta kebutuhan custom. Pesanan diproses setelah pembayaran awal atau DP diterima sesuai instruksi admin.',
  },
  {
    title: 'Revisi Tulisan dan Desain',
    body: 'Revisi tulisan dapat dilakukan selama pesanan belum masuk tahap finishing. Perubahan desain besar, warna, atau ukuran setelah proses produksi berjalan dapat dikenakan biaya tambahan atau menyesuaikan ketersediaan bunga.',
  },
  {
    title: 'Pembatalan Pesanan',
    body: 'Pembatalan dapat dipertimbangkan jika pesanan belum mulai dikerjakan. Jika bahan sudah dibeli, papan sudah diproses, atau florist sudah mulai merangkai, biaya yang sudah berjalan dapat dipotong dari pembayaran pelanggan.',
  },
  {
    title: 'Pengiriman',
    body: 'Pengiriman dilakukan sesuai jadwal yang disepakati. Keterlambatan dapat terjadi karena cuaca, kepadatan lalu lintas, akses lokasi, antrean acara, atau kondisi di luar kendali Floragate. Admin akan membantu memberi pembaruan jika terjadi kendala.',
  },
  {
    title: 'Dokumentasi dan Bukti Pengiriman',
    body: 'Floragate dapat mengirimkan foto hasil rangkaian sebelum pengiriman dan foto bukti ketika bunga tiba di lokasi. Foto dapat digunakan sebagai dokumentasi layanan internal atau portofolio, kecuali pelanggan meminta untuk tidak dipublikasikan.',
  },
  {
    title: 'Komplain dan Penanganan',
    body: 'Komplain terkait tulisan, kondisi bunga, atau pengiriman sebaiknya disampaikan segera setelah pesanan diterima dengan menyertakan foto dan kronologi. Kami akan mengecek situasi dan menawarkan solusi yang wajar sesuai kondisi pesanan.',
  },
  {
    title: 'Tanggung Jawab Pelanggan',
    body: 'Pelanggan bertanggung jawab memastikan data penerima, alamat, nomor kontak, waktu kirim, dan isi ucapan sudah benar. Kesalahan data yang dikirim pelanggan dapat memengaruhi hasil tulisan atau proses pengiriman.',
  },
  {
    title: 'Perubahan Ketentuan',
    body: 'Floragate dapat memperbarui Syarat dan Ketentuan ini untuk menyesuaikan kebutuhan operasional. Versi terbaru akan ditampilkan pada halaman ini.',
  },
];
---

<Layout title={title} description={description}>
  <section class="bg-primary text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10">
      <div class="[&_a]:text-white/78 [&_span]:text-white">
        <Breadcrumb items={[{ label: 'Syarat dan Ketentuan' }]} />
      </div>

      <div class="mt-8 grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-8 lg:gap-12 items-end">
        <div>
          <span class="inline-flex rounded-full border border-secondary/45 bg-white/8 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.18em] text-secondary-light">
            Aturan Layanan
          </span>
          <h1 class="mt-5 max-w-3xl font-serif text-3xl sm:text-5xl font-bold leading-tight">Syarat dan Ketentuan Floragate</h1>
          <p class="mt-4 max-w-3xl text-sm sm:text-base leading-relaxed text-white/78">
            Halaman ini membantu pelanggan memahami alur transaksi, pembayaran, revisi, pengiriman, dan penanganan komplain sebelum memesan bunga di Floragate.
          </p>
        </div>

        <div class="rounded-lg border border-white/15 bg-white/10 p-5 backdrop-blur-sm">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-secondary-light">Terakhir diperbarui</p>
          <p class="mt-2 font-serif text-2xl font-bold">{lastUpdated}</p>
          <p class="mt-3 text-sm leading-relaxed text-white/72">Dengan melakukan pemesanan, pelanggan dianggap memahami ketentuan dasar layanan Floragate.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-clean-ivory/70 py-14 sm:py-18">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_340px] gap-8 lg:gap-12">
        <div class="grid gap-5">
          {terms.map((item, index) => (
            <article class="rounded-lg border border-soft-cream/75 bg-white p-6 sm:p-7 shadow-[0_14px_38px_rgba(15,23,42,0.045)]">
              <div class="flex flex-col sm:flex-row gap-4 sm:gap-5">
                <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <div>
                  <h2 class="font-serif text-xl sm:text-2xl font-bold text-slate-800">{item.title}</h2>
                  <p class="mt-3 text-sm leading-relaxed text-slate-600">{item.body}</p>
                </div>
              </div>
            </article>
          ))}
        </div>

        <aside class="lg:sticky lg:top-24 h-fit space-y-5">
          <div class="rounded-lg border border-soft-cream/70 bg-white p-6 shadow-[0_22px_54px_rgba(63,75,55,0.1)]">
            <p class="font-serif text-2xl font-bold text-primary">Butuh bantuan?</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">
              Jika ada kondisi khusus seperti pengiriman mendadak, alamat luar kota, atau desain custom, konfirmasi dulu dengan admin.
            </p>
            <p class="mt-4 text-sm font-semibold text-slate-700">WhatsApp: {WHATSAPP_LABEL}</p>
            <div class="mt-5">
              <WhatsAppButton whatsappText="Halo Floragate, saya ingin bertanya tentang syarat dan ketentuan pemesanan." text="Tanya Admin" className="w-full justify-center" />
            </div>
          </div>

          <div class="rounded-lg border border-soft-cream/70 bg-primary p-6 text-white">
            <p class="font-serif text-xl font-bold">Halaman terkait</p>
            <div class="mt-4 grid gap-3 text-sm">
              <a href={withBase('/faq/')} class="rounded-md bg-white/10 px-4 py-3 text-white/86 transition-colors hover:bg-white/18">FAQ Floragate</a>
              <a href={withBase('/kebijakan-privasi/')} class="rounded-md bg-white/10 px-4 py-3 text-white/86 transition-colors hover:bg-white/18">Kebijakan Privasi</a>
              <a href={withBase('/cara-pesan/')} class="rounded-md bg-white/10 px-4 py-3 text-white/86 transition-colors hover:bg-white/18">Cara Pesan</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
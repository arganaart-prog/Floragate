---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import HeroBanner from '../components/HeroBanner.astro';
import CategoryCarousel from '../components/CategoryCarousel.astro';
import BungaPapanSection from '../components/BungaPapanSection.astro';
import HandBouquetSection from '../components/HandBouquetSection.astro';
import StandingFlowerSection from '../components/StandingFlowerSection.astro';
import BungaMejaSection from '../components/BungaMejaSection.astro';
import { PRODUCTS } from '../data/products';
import { WHATSAPP_NUMBER } from '../data/constants';
import { withBase } from '../utils/paths';

// Ambil maksimal 6 produk unggulan
const featuredProducts = PRODUCTS.filter(p => p.featured).slice(0, 6);

// SEO Meta
const title = "Toko Bunga Malang Murah & Berkualitas - Florist Cepat";
const description = "Floragate adalah toko bunga Malang murah dan berkualitas untuk bunga papan, wedding, duka cita, standing flower, hand bouquet, dan bunga meja. Harga bersahabat, bunga segar, pengerjaan cepat 3 jam.";
---

<Layout title={title} description={description}>
  
  <!-- Hero Section — Cinematic Malang Edition -->
  <HeroBanner />

  <!-- USP Section — Keunggulan Layanan Floragate -->
  <section class="pt-24 pb-20 bg-accent-bg/60 border-b border-soft-cream/40 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Section Header -->
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-secondary font-semibold text-xs tracking-widest uppercase block mb-2">Komitmen Kualitas Floragate</span>
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-slate-800 leading-tight">Toko Bunga Malang Murah dan Berkualitas untuk Setiap Momen</h2>
        
        <!-- Elegant Separator -->
        <div class="flex items-center justify-center gap-4 my-6">
          <span class="h-px bg-gradient-to-r from-transparent via-secondary/40 to-transparent w-20"></span>
          <svg class="w-4 h-4 text-secondary" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2a1.5 1.5 0 0 1 1.5 1.5c0 .351-.121.674-.323.93a4.5 4.5 0 0 0-2.354 2.354A1.5 1.5 0 0 1 12 8a1.5 1.5 0 0 1-1.5-1.5c0-.351.121-.674.323-.93a4.5 4.5 0 0 0 2.354-2.354A1.5 1.5 0 0 1 12 2zm0 20a1.5 1.5 0 0 1-1.5-1.5c0-.351.121-.674.323-.93a4.5 4.5 0 0 0 2.354-2.354c.202.256.323.579.323.93A1.5 1.5 0 0 1 12 22zm-8-10a1.5 1.5 0 0 1 1.5-1.5c.351 0 .674.121.93.323a4.5 4.5 0 0 0 2.354 2.354A1.5 1.5 0 0 1 6 12a1.5 1.5 0 0 1-1.5-1.5c0-.351.121-.674-.323-.93a4.5 4.5 0 0 0-2.354-2.354c-.202-.256-.323-.579-.323-.93A1.5 1.5 0 0 1 6 12zm16 0a1.5 1.5 0 0 1-1.5 1.5c-.351 0-.674-.121-.93-.323a4.5 4.5 0 0 0-2.354-2.354A1.5 1.5 0 0 1 18 12a1.5 1.5 0 0 1 1.5-1.5c0 .351-.121.674.323.93a4.5 4.5 0 0 0 2.354 2.354c.202.256.323.579.323.93a1.5 1.5 0 0 1-1.5 1.5zm-8-4a4 4 0 1 1 0 8 4 4 0 0 1 0-8z"/>
          </svg>
          <span class="h-px bg-gradient-to-l from-transparent via-secondary/40 to-transparent w-20"></span>
        </div>
        
        <p class="text-slate-500 text-xs sm:text-sm leading-relaxed">Setiap pesanan ditangani secara personal dengan bunga segar pilihan, harga bersahabat, dan standar kualitas tinggi untuk momen spesial Anda di Malang Raya.</p>
      </div>

      <!-- USP Cards Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        
        <!-- Card 1: Proses Cepat -->
        <div class="flex flex-col items-center text-center p-8 rounded-xl border border-soft-cream/35 bg-white/95 backdrop-blur-xs shadow-xs hover:-translate-y-1.5 hover:shadow-md hover:border-secondary/40 transition-all duration-300 group">
          <div class="w-14 h-14 bg-secondary/5 rounded-full flex items-center justify-center text-secondary mb-6 border border-secondary/10 group-hover:bg-secondary group-hover:text-white transition-colors duration-300">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h4 class="font-serif font-bold text-slate-800 text-base mb-3">Pengerjaan Kilat 3 Jam</h4>
          <p class="text-xs text-slate-500 leading-relaxed max-w-[240px]">Estimasi pengerjaan karangan bunga 3-4 jam selesai. Siap melayani kebutuhan mendesak Anda di Malang tanpa mengurangi kualitas.</p>
        </div>
        
        <!-- Card 2: Kualitas Premium -->
        <div class="flex flex-col items-center text-center p-8 rounded-xl border border-soft-cream/35 bg-white/95 backdrop-blur-xs shadow-xs hover:-translate-y-1.5 hover:shadow-md hover:border-secondary/40 transition-all duration-300 group">
          <div class="w-14 h-14 bg-secondary/5 rounded-full flex items-center justify-center text-secondary mb-6 border border-secondary/10 group-hover:bg-secondary group-hover:text-white transition-colors duration-300">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
          </div>
          <h4 class="font-serif font-bold text-slate-800 text-base mb-3">Bunga Berkualitas Harga Bersahabat</h4>
          <p class="text-xs text-slate-500 leading-relaxed max-w-[240px]">Menggunakan bunga segar pilihan berkualitas, material rapi, dan harga yang tetap kompetitif untuk kebutuhan karangan bunga murah di Malang.</p>
        </div>

        <!-- Card 3: Foto Real-Time -->
        <div class="flex flex-col items-center text-center p-8 rounded-xl border border-soft-cream/35 bg-white/95 backdrop-blur-xs shadow-xs hover:-translate-y-1.5 hover:shadow-md hover:border-secondary/40 transition-all duration-300 group">
          <div class="w-14 h-14 bg-secondary/5 rounded-full flex items-center justify-center text-secondary mb-6 border border-secondary/10 group-hover:bg-secondary group-hover:text-white transition-colors duration-300">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h4 class="font-serif font-bold text-slate-800 text-base mb-3">Laporan Foto Real-Time</h4>
          <p class="text-xs text-slate-500 leading-relaxed max-w-[240px]">Dapatkan foto hasil rangkaian bunga sebelum pengiriman dan foto bukti saat bunga tiba di lokasi demi kenyamanan Anda.</p>
        </div>

        <!-- Card 4: Kurir Terpercaya -->
        <div class="flex flex-col items-center text-center p-8 rounded-xl border border-soft-cream/35 bg-white/95 backdrop-blur-xs shadow-xs hover:-translate-y-1.5 hover:shadow-md hover:border-secondary/40 transition-all duration-300 group">
          <div class="w-14 h-14 bg-secondary/5 rounded-full flex items-center justify-center text-secondary mb-6 border border-secondary/10 group-hover:bg-secondary group-hover:text-white transition-colors duration-300">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h4 class="font-serif font-bold text-slate-800 text-base mb-3">Kurir Lokal Handal</h4>
          <p class="text-xs text-slate-500 leading-relaxed max-w-[240px]">Pengantaran amanah dan profesional oleh tim kurir lokal internal kami yang menjamin bunga sampai utuh di seluruh area Malang Raya.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-slate-800">Kategori Bunga Pilihan</h2>
        <p class="text-slate-500 text-sm mt-3 leading-relaxed">Temukan karangan bunga yang tepat untuk mendampingi setiap momen penting Anda, dari rasa duka hingga ungkapan sukacita.</p>
      </div>
      
      <CategoryCarousel />
    </div>
  </section>

  <!-- Featured Products Section -->
  <section class="py-20 bg-white border-y border-soft-cream/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12">
        <div class="max-w-xl">
          <h2 class="font-serif text-3xl sm:text-4xl font-bold text-slate-800">Produk Unggulan Terpopuler</h2>
          <p class="text-slate-500 text-sm mt-3 leading-relaxed">Kumpulan desain karangan bunga yang paling sering dipesan oleh pelanggan kami di Malang untuk berbagai keperluan.</p>
        </div>
        <a 
          href={withBase('/katalog/')} 
          class="mt-4 md:mt-0 inline-flex items-center text-sm font-semibold text-primary hover:text-secondary transition-colors group"
        >
          Lihat Semua Produk
          <svg class="h-4 w-4 ml-1.5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      
      <!-- Max 6 Featured Products Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredProducts.map(product => (
          <ProductCard product={product} variant="classic" />
        ))}
      </div>
    </div>
  </section>

  <!-- Hand Bouquet Section -->
  <HandBouquetSection />

  <!-- Bunga Papan Section -->
  <BungaPapanSection />

  <!-- Standing Flower Section -->
  <StandingFlowerSection />

  <!-- Bunga Meja Section -->
  <BungaMejaSection />

  <!-- How to Order Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-slate-800">Cara Mudah Pemesanan</h2>
        <p class="text-slate-500 text-sm mt-3 leading-relaxed">Ikuti alur praktis berikut untuk memesan karangan bunga di Malang tanpa ribet.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-8 relative">
        <!-- Connecting Line for Desktop -->
        <div class="hidden xl:block absolute top-12 left-[8%] right-[8%] h-0.5 bg-soft-cream -z-10"></div>
        
        <!-- Step 1 -->
        <div class="text-center space-y-3">
          <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center mx-auto text-xl font-bold font-serif shadow-md border-4 border-white">
            1
          </div>
          <h3 class="font-serif font-bold text-slate-800 text-base">Pilih Produk</h3>
          <p class="text-xs text-slate-500 leading-relaxed">Cari model bunga papan atau buket favorit Anda di katalog kami.</p>
        </div>

        <!-- Step 2 -->
        <div class="text-center space-y-3">
          <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center mx-auto text-xl font-bold font-serif shadow-md border-4 border-white">
            2
          </div>
          <h3 class="font-serif font-bold text-slate-800 text-base">Chat Admin WA</h3>
          <p class="text-xs text-slate-500 leading-relaxed">Klik tombol WhatsApp untuk langsung terhubung dengan admin Floragate.</p>
        </div>

        <!-- Step 3 -->
        <div class="text-center space-y-3">
          <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center mx-auto text-xl font-bold font-serif shadow-md border-4 border-white">
            3
          </div>
          <h3 class="font-serif font-bold text-slate-800 text-base">Detail Ucapan</h3>
          <p class="text-xs text-slate-500 leading-relaxed">Kirimkan draf tulisan ucapan, nama pengirim, nama penerima, dan alamat lokasi.</p>
        </div>

        <!-- Step 4 -->
        <div class="text-center space-y-3">
          <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center mx-auto text-xl font-bold font-serif shadow-md border-4 border-white">
            4
          </div>
          <h3 class="font-serif font-bold text-slate-800 text-base">Konfirmasi Harga</h3>
          <p class="text-xs text-slate-500 leading-relaxed">Admin memverifikasi total harga termasuk ongkir dan menginformasikan nominal DP.</p>
        </div>

        <!-- Step 5 -->
        <div class="text-center space-y-3">
          <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center mx-auto text-xl font-bold font-serif shadow-md border-4 border-white">
            5
          </div>
          <h3 class="font-serif font-bold text-slate-800 text-base">Bayar DP 20–50%</h3>
          <p class="text-xs text-slate-500 leading-relaxed">Lakukan pembayaran uang muka (DP) 20–50% via transfer bank untuk memulai pengerjaan.</p>
        </div>

        <!-- Step 6 -->
        <div class="text-center space-y-3">
          <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center mx-auto text-xl font-bold font-serif shadow-md border-4 border-white">
            6
          </div>
          <h3 class="font-serif font-bold text-slate-800 text-base">Pelunasan & Kirim</h3>
          <p class="text-xs text-slate-500 leading-relaxed">Setelah karangan bunga selesai, lakukan pelunasan sisa pembayaran. Baru kemudian bunga dikirim ke lokasi tujuan.</p>
        </div>
      </div>
      
      <div class="text-center mt-12">
        <a href={withBase('/cara-pesan/')} class="inline-flex items-center text-sm font-semibold text-primary hover:text-secondary transition-colors">
          Selengkapnya tentang cara pesan
          <svg class="h-4 w-4 ml-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Service Area Section -->
  <section class="py-20 bg-primary text-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-secondary text-xs font-semibold uppercase tracking-widest block mb-2">Area Layanan Florist</span>
          <h2 class="font-serif text-3xl sm:text-4xl font-bold leading-tight">Pengiriman Karangan Bunga Area Malang Raya & Batu</h2>
          <p class="text-slate-300 text-sm mt-4 leading-relaxed">
            Floragate melayani pemesanan dan pengantaran bunga untuk wilayah Malang Raya secara menyeluruh. Dengan kurir lokal berpengalaman, kami memastikan karangan bunga Anda tiba tepat waktu dan dalam kondisi prima di lokasi tujuan.
          </p>
          <div class="grid grid-cols-2 gap-4 mt-8">
            <div class="flex items-center space-x-2 text-sm text-slate-200">
              <svg class="h-5 w-5 text-secondary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Kota Malang (Gratis Ongkir)</span>
            </div>
            <div class="flex items-center space-x-2 text-sm text-slate-200">
              <svg class="h-5 w-5 text-secondary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Kota Batu</span>
            </div>
            <div class="flex items-center space-x-2 text-sm text-slate-200">
              <svg class="h-5 w-5 text-secondary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Malang Utara (Singosari, Lawang)</span>
            </div>
            <div class="flex items-center space-x-2 text-sm text-slate-200">
              <svg class="h-5 w-5 text-secondary flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Malang Selatan (Kepanjen, Bululawang)</span>
            </div>
          </div>
        </div>
        
        <!-- Interactive Service Area Map Visual Placeholder -->
        <div class="relative bg-primary-light border border-secondary/20 rounded-xl p-8 shadow-2xl flex flex-col justify-center space-y-6">
          <div class="text-center space-y-2">
            <div class="inline-flex p-3 bg-secondary/10 rounded-full text-secondary">
              <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-serif text-xl font-bold">Punya Pertanyaan Khusus?</h3>
            <p class="text-xs text-slate-300 max-w-sm mx-auto">Tanyakan pada admin apakah alamat tujuan pengiriman Anda masuk dalam jangkauan gratis ongkos kirim kami.</p>
          </div>
          <a 
            href={`https://wa.me/${WHATSAPP_NUMBER}?text=Halo%20Floragate,%20apakah%20pengiriman%20bunga%20ke%20alamat%20[Ketik%20Alamat]%20masuk%20gratis%20ongkir?`} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="w-full flex items-center justify-center px-4 py-3 bg-secondary text-primary font-semibold text-sm rounded-md hover:bg-secondary-light transition-colors duration-300"
          >
            Cek Ongkir via WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

